{
  "name": "@snaix/docs-theme",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles/*": "./src/styles/*",
    "./components/*": "./src/components/*",
    "./components/*.astro": "./src/components/*.astro",
    "./components/docs/*.astro": "./src/components/docs/*.astro",
    "./motion/*": "./src/motion/*",
    "./layouts/*.astro": "./src/layouts/*.astro",
    "./mdx-components": "./src/mdx-components.ts",
    "./tokens.css": "./src/styles/tokens.css",
    "./base.css": "./src/styles/base.css"
  },
  "peerDependencies": {
    "astro": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@snaix/docs": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "astro": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
