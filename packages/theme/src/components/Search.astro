---
/* Pagefind-powered docs search. the index lives at /pagefind/ (built by
   `pagefind --site dist`) and is loaded only on demand (first keystroke).
   desktop: a floating pill at top-right of docs content. mobile: full-
   width below the topbar. Cmd/Ctrl+K focuses it from anywhere. */
---
<div class="snx-search" data-search>
  <label class="snx-search__label">
    <span class="snx-search__kbd" aria-hidden="true">⌘K</span>
    <input
      type="search"
      class="snx-search__input"
      placeholder="search docs"
      aria-label="search docs"
      autocomplete="off"
      spellcheck="false"
      data-search-input
    />
  </label>
  <div class="snx-search__panel" data-search-panel hidden>
    <ul class="snx-search__results" data-search-results></ul>
    <div class="snx-search__empty" data-search-empty hidden>no matches.</div>
    <div class="snx-search__hint" data-search-hint>type to search · esc to close</div>
  </div>
</div>

<style>
  .snx-search {
    position: relative;
    font-family: var(--mono);
  }
  .snx-search__label {
    display: flex; align-items: stretch; gap: 0;
    border: 1px solid var(--ink);
    background: var(--paper-pure);
  }
  .snx-search__kbd {
    display: flex; align-items: center;
    padding: 0 10px;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--steel-5);
    background: var(--bg-raised);
    border-right: 1px solid var(--steel-3);
  }
  .snx-search__input {
    flex: 1;
    padding: 8px 12px;
    font: inherit;
    font-size: 13px;
    background: transparent;
    border: 0;
    outline: none;
    color: var(--fg);
    min-width: 0;
  }
  .snx-search__input::placeholder { color: var(--steel-5); }
  .snx-search__input:focus { background: var(--paper); }

  .snx-search__panel {
    position: absolute;
    top: calc(100% + 6px);
    left: 0; right: 0;
    max-height: 60vh;
    overflow-y: auto;
    background: var(--paper-pure);
    border: 1px solid var(--ink);
    z-index: 20;
    box-shadow: 4px 4px 0 var(--ink);
  }
  .snx-search__results { list-style: none; margin: 0; padding: 0; }
  .snx-search__results li { border-top: 1px solid var(--steel-3); }
  .snx-search__results li:first-child { border-top: 0; }
  .snx-search__results a {
    display: block;
    padding: 10px 14px;
    text-decoration: none;
    color: var(--ink);
    transition: background var(--t-fast);
  }
  .snx-search__results a:hover,
  .snx-search__results a.is-active { background: var(--ink); color: var(--paper-pure); }
  .snx-search__results a:hover .snx-search__result-excerpt,
  .snx-search__results a.is-active .snx-search__result-excerpt { color: var(--c-steel-3); }
  .snx-search__result-title {
    display: block;
    font-family: var(--sans);
    font-size: 14px; font-weight: 600;
    letter-spacing: -0.01em;
    text-transform: lowercase;
  }
  .snx-search__result-path {
    display: block;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--steel-5);
    margin-bottom: 4px;
  }
  .snx-search__result-excerpt {
    display: block;
    font-family: var(--sans);
    font-size: 12px;
    line-height: 1.5;
    color: var(--steel-7);
    margin-top: 4px;
  }
  .snx-search__result-excerpt mark {
    background: var(--c-yellow); color: var(--c-ink-0);
    padding: 0 2px;
  }

  .snx-search__empty,
  .snx-search__hint {
    padding: 12px 14px;
    font-size: 11px;
    color: var(--steel-5);
    letter-spacing: 0.06em;
  }
  .snx-search__empty { color: var(--red); }
</style>

<script is:inline>
  (() => {
    const bind = () => {
      const root = document.querySelector('[data-search]');
      if (!root) return;
      const input = root.querySelector('[data-search-input]');
      const panel = root.querySelector('[data-search-panel]');
      const list = root.querySelector('[data-search-results]');
      const empty = root.querySelector('[data-search-empty]');
      const hint = root.querySelector('[data-search-hint]');

      let pf = null;
      let pfLoading = false;
      let activeIdx = -1;
      let results = [];

      const loadPagefind = async () => {
        if (pf || pfLoading) return pf;
        pfLoading = true;
        try {
          pf = await import(/* @vite-ignore */ '/pagefind/pagefind.js');
          await pf.init();
        } catch (e) {
          console.warn('[search] pagefind not available (is the site built?)', e);
        }
        pfLoading = false;
        return pf;
      };

      const show = () => { panel.removeAttribute('hidden'); };
      const hide = () => { panel.setAttribute('hidden', ''); activeIdx = -1; };
      const setActive = (i) => {
        activeIdx = i;
        list.querySelectorAll('a').forEach((el, j) => {
          el.classList.toggle('is-active', i === j);
          if (i === j) el.scrollIntoView({ block: 'nearest' });
        });
      };

      const render = async (query) => {
        hint.setAttribute('hidden', '');
        empty.setAttribute('hidden', '');
        list.innerHTML = '';
        if (!query) {
          hint.removeAttribute('hidden');
          return;
        }
        if (!pf) await loadPagefind();
        if (!pf) return;
        const search = await pf.debouncedSearch(query, {}, 200);
        if (search === null) return;
        const top = search.results.slice(0, 8);
        results = await Promise.all(top.map((r) => r.data()));
        if (results.length === 0) {
          empty.removeAttribute('hidden');
          return;
        }
        list.innerHTML = '';
        for (const d of results) {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = d.url;
          const product = (d.url.match(/^\/([^/]+)\//)?.[1] ?? '').toUpperCase();
          a.innerHTML =
            `<span class="snx-search__result-path">${product} / ${d.meta?.section ?? 'docs'}</span>` +
            `<span class="snx-search__result-title">${d.meta?.title ?? d.url}</span>` +
            `<span class="snx-search__result-excerpt">${d.excerpt ?? ''}</span>`;
          li.appendChild(a);
          list.appendChild(li);
        }
      };

      input.addEventListener('focus', show);
      input.addEventListener('input', (e) => {
        show();
        render(e.target.value.trim());
      });
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
          e.preventDefault();
          input.focus();
          input.select();
        } else if (e.key === 'Escape' && document.activeElement === input) {
          hide();
          input.blur();
        } else if (document.activeElement === input && results.length > 0) {
          if (e.key === 'ArrowDown') { e.preventDefault(); setActive(Math.min(activeIdx + 1, results.length - 1)); }
          else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(Math.max(activeIdx - 1, 0)); }
          else if (e.key === 'Enter' && activeIdx >= 0) {
            e.preventDefault();
            const a = list.querySelectorAll('a')[activeIdx];
            if (a) window.location.href = a.href;
          }
        }
      });
      document.addEventListener('click', (e) => {
        if (!root.contains(e.target)) hide();
      });
    };

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
    else bind();
  })();
</script>
