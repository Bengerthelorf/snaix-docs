---
import { withBase } from '../utils/href.ts';

interface NavItem {
  id: string;
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  brand?: string;
  version?: string;
  nav?: NavItem[];
  current?: string;
  portalHref?: string;
  githubHref?: string;
}

const DEFAULT_NAV: NavItem[] = [
  { id: 'home', label: 'index', href: '/' },
  { id: 'cli', label: 'commands', href: '/cli' },
  { id: 'docs', label: 'docs', href: '/docs' },
  { id: 'download', label: 'install', href: '/install' },
  { id: 'changelog', label: 'changelog', href: '/changelog' },
  { id: 'about', label: 'manifesto', href: '/about' },
];

const {
  brand = 'bcmr',
  version = '',
  current = 'home',
  portalHref = '/',
  githubHref = '#',
  nav = DEFAULT_NAV,
} = Astro.props;
---
<header class="topbar" data-topbar>
  <a href={portalHref} class="topbar-brand" title="back to snaix.homes">
    <svg class="topbar-logo" viewBox="0 0 40 40" aria-hidden="true">
      <slot name="logo">
        <rect x="0" y="0" width="20" height="20" fill="var(--red)" />
        <rect x="20" y="0" width="20" height="20" fill="var(--paper-pure)" stroke="var(--ink)" />
        <circle cx="10" cy="30" r="10" fill="var(--blue)" />
        <polygon points="20,40 40,40 40,20" fill="var(--yellow)" />
      </slot>
    </svg>
    <span class="topbar-wordmark">{brand}</span>
    {version && <span class="topbar-version">{version}</span>}
  </a>
  <nav class="topbar-nav" id="topbar-nav">
    {nav.map((n) => (
      <a
        href={n.external ? n.href : withBase(n.href)}
        target={n.external ? '_blank' : undefined}
        rel={n.external ? 'noopener' : undefined}
        class:list={['topbar-link', { 'is-active': current === n.id }]}
      >
        {n.label}
      </a>
    ))}
  </nav>
  <div class="topbar-right">
    <a class="topbar-gh" href={githubHref}>github↗︎</a>
  </div>
  <button
    type="button"
    class="topbar-burger"
    aria-label="menu"
    aria-controls="mobile-drawer"
    aria-expanded="false"
    data-burger
  >
    <span class="burger-bar b1" /><span class="burger-bar b2" /><span class="burger-bar b3" />
  </button>

  <div id="mobile-drawer" class="mobile-drawer" aria-hidden="true" data-drawer>
    <div class="mobile-drawer-inner">
      <div class="mobile-drawer-head">
        <div class="t-small" style="color: var(--steel-5);">navigate</div>
        <div class="mobile-drawer-rule" />
      </div>
      <nav class="mobile-nav">
        {nav.map((n, i) => (
          <a
            href={n.external ? n.href : withBase(n.href)}
            target={n.external ? '_blank' : undefined}
            rel={n.external ? 'noopener' : undefined}
            class:list={['mobile-nav-link', { 'is-active': current === n.id }]}
            style={`--mn-delay: ${80 + i * 40}ms`}
          >
            <span class="mobile-nav-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="mobile-nav-label">{n.label}</span>
            <span class="mobile-nav-arrow">→</span>
          </a>
        ))}
      </nav>
      <div class="mobile-drawer-foot">
        <a class="topbar-gh" href={githubHref}>github↗︎</a>
      </div>
      <div class="mobile-drawer-marks" aria-hidden="true">
        <span class="mk mk-sq" />
        <span class="mk mk-ci" />
        <span class="mk mk-tr" />
      </div>
    </div>
  </div>
</header>
