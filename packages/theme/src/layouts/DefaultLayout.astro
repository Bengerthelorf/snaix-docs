---
import ThemeInit from './ThemeInit.astro';
import FontLinks from './FontLinks.astro';
import { ThemeToggle } from '../components/ThemeToggle.tsx';

import '../styles/tokens.css';
import '../styles/theme.css';
import '../styles/motion.css';
import '../styles/layout.css';
import '../styles/pages.css';
import '../styles/directives.css';
import '../styles/portal.css';
import '../styles/home.css';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  lang?: string;
  dir?: 'ltr' | 'rtl';
  favicon?: string;
}
const { title, description, bodyClass, lang = 'en', dir, favicon } = Astro.props;
/* arabic, hebrew, persian, urdu — flip layout when explicit or when the
   lang code is known rtl. */
const resolvedDir = dir ?? (/^(ar|he|fa|ur)\b/i.test(lang) ? 'rtl' : undefined);
/* Pick a per-product favicon by URL path. Portal / design-system / about /
   404 all fall through to the universal snaix mark. */
const productSlug = Astro.url.pathname.match(/^\/(bcmr|pikpaktui|iconchanger|claudit)\//)?.[1];
const faviconHref = favicon ?? (productSlug ? `/icons/${productSlug}.svg` : '/icons/snaix.svg');
---
<!doctype html>
<html lang={lang} dir={resolvedDir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <ThemeInit />
    <FontLinks />
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
    <ThemeToggle client:load />
    <script is:inline>
      (() => {
        const KEY = 'snx-code-tabs';
        const readPref = () => {
          try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch { return {}; }
        };
        const writePref = (pref) => {
          try { localStorage.setItem(KEY, JSON.stringify(pref)); } catch {}
        };
        const selectByLabel = (group, label) => {
          const tabs = group.querySelectorAll('.snx-code-tabs__tab');
          const panels = group.querySelectorAll('.snx-code-tabs__panel');
          let idx = [...tabs].findIndex((t) => t.dataset.tabLabel === label);
          if (idx < 0) idx = 0;
          tabs.forEach((t, i) => {
            const on = i === idx;
            t.setAttribute('aria-selected', on ? 'true' : 'false');
            t.setAttribute('tabindex', on ? '0' : '-1');
          });
          panels.forEach((p, i) => { if (i === idx) p.removeAttribute('hidden'); else p.setAttribute('hidden', ''); });
        };
        const sync = (label) => {
          const pref = readPref();
          pref._last = label;
          writePref(pref);
          document.querySelectorAll('[data-code-tabs]').forEach((g) => {
            if ([...g.querySelectorAll('.snx-code-tabs__tab')].some((t) => t.dataset.tabLabel === label)) {
              selectByLabel(g, label);
            }
          });
        };
        const init = () => {
          const pref = readPref();
          document.querySelectorAll('[data-code-tabs]').forEach((g) => {
            if (pref._last) selectByLabel(g, pref._last);
            g.querySelectorAll('.snx-code-tabs__tab').forEach((tab) => {
              tab.addEventListener('click', () => sync(tab.dataset.tabLabel));
            });
            g.querySelectorAll('.snx-code-tabs__copy').forEach((btn) => {
              btn.addEventListener('click', async () => {
                const pre = btn.parentElement?.querySelector('pre');
                if (!pre) return;
                try {
                  await navigator.clipboard.writeText(pre.innerText);
                  btn.classList.add('is-copied');
                  btn.textContent = 'copied';
                  setTimeout(() => { btn.classList.remove('is-copied'); btn.textContent = 'copy'; }, 1400);
                } catch {}
              });
            });
          });
        };
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
        else init();
      })();
    </script>
  </body>
</html>
