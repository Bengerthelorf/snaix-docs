---
import ThemeInit from './ThemeInit.astro';
import FontLinks from './FontLinks.astro';
import { ThemeToggle } from '../components/ThemeToggle.tsx';

import '../styles/tokens.css';
import '../styles/theme.css';
import '../styles/motion.css';
import '../styles/layout.css';
import '../styles/pages.css';
import '../styles/directives.css';
import '../styles/portal.css';
import '../styles/home.css';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  lang?: string;
  dir?: 'ltr' | 'rtl';
  favicon?: string;
  ogImage?: string;
}
const { title, description, bodyClass, lang = 'en', dir, favicon, ogImage } = Astro.props;
/* arabic, hebrew, persian, urdu — flip layout when explicit or when the
   lang code is known rtl. */
const resolvedDir = dir ?? (/^(ar|he|fa|ur)\b/i.test(lang) ? 'rtl' : undefined);
/* Pick a per-product favicon + og card by URL path. Portal / design-system /
   about / 404 all fall through to the universal snaix mark. */
const productSlug = Astro.url.pathname.match(/^\/(bcmr|pikpaktui|iconchanger|claudit)\//)?.[1];
const faviconHref = favicon ?? (productSlug ? `/icons/${productSlug}.svg` : '/icons/snaix.svg');
const ogImageHref = ogImage ?? (productSlug ? `/og/${productSlug}.png` : '/og/snaix.png');
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://app.snaix.homes').toString();
const ogImageAbs = new URL(ogImageHref, Astro.site ?? 'https://app.snaix.homes').toString();
const ogDescription = description ?? 'small tools, big years. four open-source tools — cli, tui, macos native — across one bench.';
---
<!doctype html>
<html lang={lang} dir={resolvedDir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="snaix.homes" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageAbs} />
    <ThemeInit />
    <FontLinks />
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
    <ThemeToggle client:load />
    <script is:inline>
      (() => {
        const KEY = 'snx-code-tabs';
        const readPref = () => {
          try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch { return {}; }
        };
        const writePref = (pref) => {
          try { localStorage.setItem(KEY, JSON.stringify(pref)); } catch {}
        };
        const selectByLabel = (group, label) => {
          const tabs = group.querySelectorAll('.snx-code-tabs__tab');
          const panels = group.querySelectorAll('.snx-code-tabs__panel');
          let idx = [...tabs].findIndex((t) => t.dataset.tabLabel === label);
          if (idx < 0) idx = 0;
          tabs.forEach((t, i) => {
            const on = i === idx;
            t.setAttribute('aria-selected', on ? 'true' : 'false');
            t.setAttribute('tabindex', on ? '0' : '-1');
          });
          panels.forEach((p, i) => { if (i === idx) p.removeAttribute('hidden'); else p.setAttribute('hidden', ''); });
        };
        const sync = (label) => {
          const pref = readPref();
          pref._last = label;
          writePref(pref);
          document.querySelectorAll('[data-code-tabs]').forEach((g) => {
            if ([...g.querySelectorAll('.snx-code-tabs__tab')].some((t) => t.dataset.tabLabel === label)) {
              selectByLabel(g, label);
            }
          });
        };
        const init = () => {
          const pref = readPref();
          document.querySelectorAll('[data-code-tabs]').forEach((g) => {
            if (pref._last) selectByLabel(g, pref._last);
            g.querySelectorAll('.snx-code-tabs__tab').forEach((tab) => {
              tab.addEventListener('click', () => sync(tab.dataset.tabLabel));
            });
            g.querySelectorAll('.snx-code-tabs__copy').forEach((btn) => {
              btn.addEventListener('click', async () => {
                const pre = btn.parentElement?.querySelector('pre');
                if (!pre) return;
                try {
                  await navigator.clipboard.writeText(pre.innerText);
                  btn.classList.add('is-copied');
                  btn.textContent = 'copied';
                  setTimeout(() => { btn.classList.remove('is-copied'); btn.textContent = 'copy'; }, 1400);
                } catch {}
              });
            });
          });
        };
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
        else init();
      })();
    </script>
    <script is:inline>
      (() => {
        const bind = () => {
          document.querySelectorAll('[data-topbar]').forEach((bar) => {
            const btn = bar.querySelector('[data-burger]');
            const drawer = bar.querySelector('[data-drawer]');
            if (!btn || !drawer) return;
            let prevOverflow = '';
            const close = () => {
              bar.removeAttribute('data-open');
              drawer.classList.remove('is-open');
              drawer.setAttribute('aria-hidden', 'true');
              btn.setAttribute('aria-expanded', 'false');
              document.body.style.overflow = prevOverflow;
            };
            const open = () => {
              bar.setAttribute('data-open', '');
              drawer.classList.add('is-open');
              drawer.setAttribute('aria-hidden', 'false');
              btn.setAttribute('aria-expanded', 'true');
              prevOverflow = document.body.style.overflow;
              document.body.style.overflow = 'hidden';
            };
            btn.addEventListener('click', (e) => {
              e.stopPropagation();
              bar.hasAttribute('data-open') ? close() : open();
            });
            drawer.addEventListener('click', (e) => {
              if (e.target.closest('a')) close();
            });
            document.addEventListener('keydown', (e) => {
              if (e.key === 'Escape' && bar.hasAttribute('data-open')) close();
            });
          });
        };
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
        else bind();
      })();
    </script>
  </body>
</html>
