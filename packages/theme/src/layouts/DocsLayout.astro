---
import DefaultLayout from './DefaultLayout.astro';
import TopBar from '../components/TopBar.astro';
import Footer from '../components/Footer.astro';
import MathStyles from '../components/MathStyles.astro';
import MermaidLoader from '../components/MermaidLoader.astro';
import type { LangOption } from '../components/LangSwitcher.astro';
import { withBase } from '../utils/href.ts';
import type { ProductIntegration } from '@snaix/docs';

interface NavItem {
  slug: string;
  title: string;
  href?: string;
}

interface NavSection {
  label: string;
  items: NavItem[];
}

interface TocItem {
  slug: string;
  text: string;
  depth: number;
}

interface PagerLink {
  title: string;
  href: string;
}

interface Props {
  product: ProductIntegration;
  brand?: string;
  version?: string;
  current: string;
  nav: NavSection[];
  title: string;
  description?: string;
  breadcrumb?: string[];
  source?: { path: string; url?: string };
  toc?: TocItem[];
  locale?: string;
  languages?: LangOption[];
  docsBase?: string;
  tocLabel?: string;
  math?: boolean;
  mermaid?: boolean;
  topNav?: { id: string; label: string; href: string; external?: boolean }[];
  currentTab?: string;
  pager?: { prev?: PagerLink; next?: PagerLink };
}

const {
  product,
  brand = product.title,
  version = product.version,
  current,
  nav,
  title,
  description,
  breadcrumb = [],
  source,
  toc = [],
  locale = 'en',
  languages = [],
  docsBase = '/docs',
  tocLabel = 'on this page',
  math = false,
  mermaid = false,
  topNav,
  currentTab = 'docs',
  pager,
} = Astro.props;

function itemHref(item: NavItem) {
  if (item.href) return withBase(item.href);
  return withBase(`${docsBase}/${item.slug}`);
}
---
<DefaultLayout title={`${brand} · ${title}`} description={description} lang={locale}>
  {math && <MathStyles slot="head" />}
  <div class="page docs">
    <TopBar
      brand={brand}
      version={version}
      current={currentTab}
      nav={topNav}
      githubHref={product.githubUrl}
    >
      <Fragment slot="logo">
        <circle cx="20" cy="20" r="18" fill={product.accent} />
        <rect x="12" y="12" width="16" height="16" fill="var(--paper-pure)" />
        <rect x="14" y="14" width="5" height="5" fill="var(--red)" />
        <rect x="21" y="21" width="5" height="5" fill="var(--yellow)" />
      </Fragment>
    </TopBar>

    <div class="docs-layout">
      <aside class="docs-nav">
        <div style="margin-bottom: 20px;">
          <div class="t-small" style={`color: ${product.accent}; margin-bottom: 8px;`}>{brand} / docs</div>
          {version && <div class="t-mono-sm" style="color: var(--steel-5);">{version}</div>}
        </div>
        {nav.map((g) => (
          <div class="docs-nav-section">
            <div class="docs-nav-section-title">{g.label}</div>
            {g.items.map((it) => (
              <a href={itemHref(it)} class={it.slug === current ? 'is-active' : ''}>
                {it.title}
              </a>
            ))}
          </div>
        ))}
      </aside>

      <article class="docs-content">
        {breadcrumb.length > 0 && (
          <div class="docs-breadcrumb">
            {breadcrumb.slice(0, -1).map((b) => <Fragment>{b} / </Fragment>)}
            <span>{breadcrumb[breadcrumb.length - 1]}</span>
          </div>
        )}
        <h1 class="docs-title lower">{title}</h1>
        {description && <p class="docs-subtitle">{description}</p>}

        <slot />

        {pager && (
          <div class="docs-pager">
            {pager.prev ? (
              <a href={pager.prev.href} class="is-prev">
                <div class="pager-label">← previous</div>
                <div class="pager-title">{pager.prev.title}</div>
              </a>
            ) : <span />}
            {pager.next ? (
              <a href={pager.next.href} class="is-next">
                <div class="pager-label">next →</div>
                <div class="pager-title">{pager.next.title}</div>
              </a>
            ) : <span />}
          </div>
        )}
      </article>

      <aside class="docs-toc">
        <div class="docs-toc-label">{tocLabel}</div>
        {toc.map((t) => (
          <a href={`#${t.slug}`} class={t.depth > 2 ? 'is-l2' : ''}>{t.text}</a>
        ))}
        {source && (
          <div style="margin-top: 20px; padding-top: 14px; border-top: 1px solid var(--steel-3);">
            <div class="docs-toc-label">source</div>
            <div class="t-mono-sm" style="color: var(--steel-5); padding: 4px 0;">{source.path}</div>
            {source.url && (
              <Fragment>
                <a href={source.url}>edit on github ↗︎</a>
                <a href={`${product.githubUrl}/issues/new`}>report issue</a>
              </Fragment>
            )}
          </div>
        )}
      </aside>
    </div>

    <Footer product={product} locale={locale} languages={languages} />
  </div>
  {mermaid && <MermaidLoader />}
</DefaultLayout>
