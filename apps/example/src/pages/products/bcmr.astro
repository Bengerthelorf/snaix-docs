---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import MarginNote from '@snaix/docs-theme/components/MarginNote.astro';
import {
  BlockReveal,
  Scramble,
  Tally,
  Typewriter,
  CommandStream,
} from '@snaix/docs-theme';
import type { CmdLine } from '@snaix/docs-theme';
import { snaixConfig } from 'virtual:snaix-config';

const terminalScript: CmdLine[] = [
  { type: 'prompt', text: 'bcmr cp ./dataset node-04:/srv/' },
  { type: 'out',    text: 'scanning source …  2,481 files · 14.2 gb', pause: 200 },
  { type: 'out',    text: 'handshake (ssh)……  ok', pause: 140 },
  { type: 'out',    text: 'direct-tcp fast path …  negotiated', pause: 180 },
  { type: 'ok',     text: 'complete · 34.5s · 412 mb/s avg · all blake3 verified', pause: 260 },
  { type: 'blank' },
  { type: 'prompt', text: 'bcmr cp --resume ./big.iso node-04:/iso/', pause: 320 },
  { type: 'out',    text: 'found partial — resuming from byte 4,298,571,264', pause: 180 },
  { type: 'ok',     text: 'complete · 12.1s · hashes match', pause: 160 },
  { type: 'blank' },
  { type: 'prompt', text: 'bcmr mv photos/ cold-storage:/2024/', pause: 280 },
  { type: 'out',    text: 'copying……  ok     verifying……  ok', pause: 180 },
  { type: 'warn',   text: 'source sealed only after verify. safe to abort.', pause: 200 },
  { type: 'ok',     text: 'moved · 1,204 files · source removed', pause: 180 },
];

const features = [
  { n: '01', t: 'blake3 everywhere', d: 'every chunk is hashed on both ends. a verified transfer is the only kind of transfer bcmr will tell you succeeded.', mark: 'sq', color: 'var(--ink)' },
  { n: '02', t: 'crash · resume', d: 'kill the process, pull the cable, lose the ssh session. run the same command again and bcmr picks up at the last verified byte.', mark: 'ci', color: 'var(--red)' },
  { n: '03', t: 'local + ssh', d: 'one verb, two universes. paths look like cp. remote paths look like scp. no mental tax for which tool to reach for.', mark: 'tr', color: 'var(--blue)' },
  { n: '04', t: 'reflink · sparse', d: 'on apfs, btrfs, xfs and zfs, bcmr uses clone_file / reflink / copy_file_range. a 100 gb copy takes milliseconds if the fs supports it.', mark: 'sq', color: 'var(--yellow)' },
  { n: '05', t: 'lz4 · zstd · dedup', d: 'optional on-the-wire compression with lz4 or zstd. content-addressed dedup avoids sending bytes you already have.', mark: 'ci', color: 'var(--ink)' },
  { n: '06', t: 'json + tui', d: 'use it in a script with --json. use it in a terminal with --tui. same binary. same commands. different skins.', mark: 'tr', color: 'var(--red)' },
] as const;
---
<DefaultLayout title="bcmr — better copy · move · remove">
  <div class="page home">
    <TopBar brand={snaixConfig.title} version={snaixConfig.version} current="home" logoVariant="product" showStatus={false} githubHref="https://github.com/melodic-lab/bcmr" />

    <!-- hero -->
    <section class="hero">
      <div class="hero-top rule-b">
        <span class="t-mono-sm">bcmr / better copy move remove</span>
        <span class="t-mono-sm">one verb for local + ssh</span>
        <span class="t-mono-sm">v0.9.1 · 2026.04.14</span>
      </div>

      <div class="hero-grid grid12">
        <div class="hero-headline">
          <div class="hero-eyebrow">
            <span class="t-small">§ 01 · overview</span>
            <span class="t-mono-sm" style="color: var(--steel-5);">
              <Typewriter client:load text="// cp + mv + scp — but honest." speed={24} delay={300} />
            </span>
          </div>
          <h1 class="t-display lower">
            <span class="hl-line"><BlockReveal client:load delay={400} duration={520}>copy.</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:load delay={760} duration={520} color="var(--red)">move.</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:load delay={1120} duration={520} color="var(--blue)">remove.</BlockReveal></span>
          </h1>

          <p class="hero-lede">
            bcmr is a modern drop-in replacement for cp, mv, and scp.
            blake3 checksums on every byte. resumable after crash. local
            paths and ssh paths accepted in the same command. one verb,
            verified on both ends.
          </p>

          <div class="hero-cta">
            <a class="btn-block" href="/install">↳ install v0.9.1</a>
            <a class="btn-block is-ghost" href="/docs">read the docs</a>
            <span class="hero-cta-meta t-mono-sm">
              ⌘ <span>brew install melodic-lab/tap/bcmr</span>
            </span>
          </div>
        </div>

        <aside class="hero-device">
          <div class="device-head">
            <div class="t-small">transfer.live</div>
            <div class="chip is-blue"><span class="dot"/>verified</div>
          </div>
          <div style="padding: 16px; background: var(--ink); color: var(--paper-pure); font-family: var(--mono); font-size: 12px; line-height: 1.7;">
            <div style="color: var(--steel-5);"># 14.2 gb · local → ssh</div>
            <div>src  <b style="color: var(--paper-pure);">./dataset/</b></div>
            <div>dst  <b style="color: var(--paper-pure);">node-04:/srv/</b></div>
            <div style="margin: 10px 0; color: var(--steel-3);">────────────────</div>
            <div>rate <span style="color: var(--yellow);"><Tally client:load to={412} duration={900} suffix=" mb/s" /></span></div>
            <div>eta  <span style="color: var(--yellow);">00:00:12</span></div>
            <div>hash <span style="color: var(--blue);">blake3</span> ok</div>
            <div style="margin-top: 10px; background: var(--steel-9); height: 6px; position: relative; overflow: hidden;">
              <div style="position: absolute; inset: 0; right: 18%; background: var(--blue);" />
            </div>
            <div style="margin-top: 6px; display: flex; justify-content: space-between; color: var(--steel-5);">
              <span>82%</span><span>11.6 / 14.2 gb</span>
            </div>
          </div>
          <div class="device-footline">
            <span class="t-mono-sm">direct-tcp · fast path</span>
            <span class="t-mono-sm" style="color: var(--blue);">● live</span>
          </div>
        </aside>
      </div>

      <div class="hero-ribbon rule-t">
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">01</span>
            <span class="ribbon-label"><Scramble client:load text="blake3 verified" delay={200} /></span>
          </div>
          <div class="ribbon-sub">every byte hashed on both ends. corruption is loud, not silent.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">02</span>
            <span class="ribbon-label"><Scramble client:load text="resumable" delay={350} /></span>
          </div>
          <div class="ribbon-sub">kill the process, pull the cable. rerun the same command. pick up exactly where it stopped.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">03</span>
            <span class="ribbon-label"><Scramble client:load text="local + ssh" delay={500} /></span>
          </div>
          <div class="ribbon-sub">one verb, two universes. no mental tax deciding between cp and scp.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">04</span>
            <span class="ribbon-label"><Scramble client:load text="reflink · sparse · dedup" delay={650} /></span>
          </div>
          <div class="ribbon-sub">on apfs/btrfs/xfs/zfs, 100 gb in milliseconds. content-addressed dedup over the wire.</div>
        </div>
      </div>
    </section>

    <!-- § 02 · one verb -->
    <section class="home-section">
      <div class="section-head">
        <div class="section-head-left">
          <div class="t-small">§ 02 · one verb</div>
          <h2 class="t-h1 lower">local, ssh,<br/>same command.</h2>
        </div>
        <div class="section-head-right">
          <p class="t-body">
            cp and scp treat local and remote as two different universes.
            bcmr treats them as two different paths. <code class="inline-code">bcmr cp</code> works
            the same way whether you are moving 3 mb across a disk or
            300 gb across a datacenter.
          </p>
        </div>
      </div>

      <div class="terminal-shell">
        <div class="terminal-chrome">
          <div class="terminal-lights"><span/><span/><span/></div>
          <div class="t-mono-sm">zsh · bcmr 0.9.1</div>
          <div class="t-mono-sm" style="color: var(--steel-5);">~/work</div>
        </div>
        <div class="terminal-body">
          <CommandStream client:load lines={terminalScript} />
        </div>
      </div>
    </section>

    <!-- § 03 · features -->
    <section class="home-section home-principles">
      <div class="section-head">
        <div class="section-head-left">
          <div class="t-small">§ 03 · features</div>
          <h2 class="t-h1 lower">six things<br/>it does right.</h2>
        </div>
        <div class="section-head-right">
          <MarginNote num={1}>
            these are promises, not descriptions. if you find one violated,
            that is a bug we want to hear about.
          </MarginNote>
        </div>
      </div>

      <div class="principles-grid">
        {features.map((it) => (
          <div class="principle">
            <div class="principle-n t-mono">{it.n}</div>
            <div class="principle-title t-h3 lower">{it.t}</div>
            <div class="principle-d">{it.d}</div>
            <div class="principle-mark">
              {it.mark === 'sq' && <div style={`width: 14px; height: 14px; background: ${it.color};`} />}
              {it.mark === 'ci' && <div style={`width: 14px; height: 14px; border-radius: 50%; background: ${it.color};`} />}
              {it.mark === 'tr' && <div style={`width: 0; height: 0; border-left: 8px solid transparent; border-right: 8px solid transparent; border-bottom: 14px solid ${it.color};`} />}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- metrics -->
    <section class="home-section home-metrics">
      <div class="metrics-strip">
        <div class="metric">
          <div class="metric-num t-display"><Tally client:load to={412} suffix=" mb/s" duration={1100} /></div>
          <div class="metric-cap t-small">direct-tcp · peak</div>
        </div>
        <div class="metric">
          <div class="metric-num t-display"><Tally client:load to={100} suffix="%" duration={1000} /></div>
          <div class="metric-cap t-small">blake3 coverage</div>
        </div>
        <div class="metric">
          <div class="metric-num t-display"><Tally client:load to={4} duration={800} /></div>
          <div class="metric-cap t-small">platforms supported</div>
        </div>
        <div class="metric">
          <div class="metric-num t-display">
            <Tally client:load to={0} duration={600} /><span style="font-size: 0.5em; vertical-align: super; margin-left: 6px;">kb</span>
          </div>
          <div class="metric-cap t-small">telemetry · forever</div>
        </div>
      </div>
    </section>

    <!-- § 04 · begin -->
    <section class="home-cta">
      <div class="cta-inner">
        <div class="t-small" style="color: var(--steel-3);">§ 04 · begin</div>
        <h2 class="t-display lower" style="color: var(--paper-pure);">
          <BlockReveal client:load delay={200} color="var(--yellow)">one verb.</BlockReveal><br/>
          <BlockReveal client:load delay={700} color="var(--red)">verified.</BlockReveal><br/>
          <BlockReveal client:load delay={1200} color="var(--blue)">resumable.</BlockReveal>
        </h2>
        <div class="cta-buttons">
          <a class="btn-block" style="background: var(--paper-pure); color: var(--ink); border-color: var(--paper-pure);" href="/install">
            install bcmr ↳
          </a>
          <a class="btn-block" style="background: transparent; color: var(--paper-pure); border-color: var(--paper-pure);" href="/docs">
            read docs
          </a>
        </div>
        <div class="cta-small t-mono-sm">
          mit licensed · nothing phones home · open source since 2024
        </div>
      </div>
    </section>

    <Footer brand={snaixConfig.title} />
  </div>
</DefaultLayout>
