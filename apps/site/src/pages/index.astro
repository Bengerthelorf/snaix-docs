---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import PortalTile from '@snaix/docs-theme/components/portal/PortalTile.astro';
import {
  BlockReveal,
  Tally,
  Typewriter,
} from '@snaix/docs-theme';
import { snaixConfig } from 'virtual:snaix-config';

const { stats, build, ticker, activity, edition, products } = snaixConfig.siteData;

const year = new Date().getFullYear();
---
<DefaultLayout title="snaix.homes">
  <div class="portal">
    <header class="p-mast">
      <div class="p-mast-top">
        <div class="mast-brand">snaix <b>//</b> personal index</div>
        <div>{edition} · {build.date}</div>
        <div>open source</div>
      </div>

      <div class="p-mast-shapes" aria-hidden="true">
        <div class="pms-sq" />
        <div class="pms-ci" />
        <div class="pms-tr" />
        <div class="pms-bar1" />
        <div class="pms-bar2" />
      </div>

      <h1 class="p-mast-title">
        <span class="w1"><BlockReveal client:visible delay={100} duration={520}>four</BlockReveal></span>
        <span class="w2"><BlockReveal client:visible delay={400} duration={520} color="var(--red)">tools</BlockReveal></span>
        <span class="w3"><BlockReveal client:visible delay={700} duration={520} color="var(--blue)">one hand</BlockReveal><span class="slash">/</span></span>
      </h1>

      <div class="p-mast-sub">
        <div class="slot">
          <span class="t-small">01 — what this is</span>
          open source tools across cli, tui, and macos native — with flutter on the way. permissively licensed. source code in the open.
        </div>
        <div class="slot">
          <span class="t-small">02 — by the numbers</span>
          <div class="kv">
            <div><span>tools</span> · {stats.shippingTools} shipping</div>
            <div><span>stars</span> · <Tally client:visible to={stats.githubStars} duration={1200} /></div>
            <div><span>docs</span> · {stats.locales} languages</div>
            <div><span>licence</span> · mit / apache</div>
          </div>
        </div>
        <div class="slot">
          <span class="t-small">03 — get started</span>
          <div class="kv" style="margin-bottom: 12px;">
            <Typewriter client:visible text="$ curl -sSf get.snaix.homes | sh" speed={22} delay={800} cursor={false} />
          </div>
          <a href="#wall" class="btn-block" style="padding: 10px 16px; font-size: 11px;">↳ pick a tool</a>
        </div>
      </div>
    </header>

    <div class="p-ticker">
      <div class="p-ticker-track">
        {[...ticker, ...ticker, ...ticker].map((it) => (
          <Fragment><span>{it}</span><span class="sep">●</span></Fragment>
        ))}
      </div>
    </div>

    <section class="p-wall" id="wall">
      <div class="p-wall-head">
        <h2>the <em>wall</em>.</h2>
        <div class="t-mono-sm" style="color: var(--steel-5);">§ 01 · products</div>
      </div>

      <div class="p-wall-grid">
        {products.map((p) => (
          <PortalTile
            variant={p.variant}
            n={p.eyebrow}
            name={p.name}
            tag={p.tag}
            description={p.description}
            metaLeft={p.metaLeft}
            metaRight={p.metaRight}
            href={p.href}
          />
        ))}
      </div>
    </section>

    <section class="p-activity">
      <div class="p-activity-left">
        <div class="t-small" style="color: var(--red); margin-bottom: 12px; display: block;">§ 02 · activity</div>
        <h2 class="lower">
          <BlockReveal client:visible>shipping</BlockReveal><br/>
          <BlockReveal client:visible delay={200} color="var(--blue)">out loud.</BlockReveal>
        </h2>
        <p>
          no roadmap theatre. changes go in as they land. below is a
          curated digest of recent releases and doc updates across the
          four repos — not a live feed.
        </p>
        <div style="margin-top: 30px; display: flex; gap: 10px;">
          <span class="chip is-red"><span class="dot"/>rec</span>
          <span class="chip is-yellow"><span class="dot"/>wip</span>
          <span class="chip is-blue"><span class="dot"/>shipped</span>
        </div>
      </div>

      <div class="p-stream">
        <div class="p-stream-head">
          <span><span class="live-dot" />live feed</span>
          <span>updated {build.date}</span>
        </div>
        {activity.map((r) => (
          <div class="p-stream-row">
            <span class="r-time">{r.time}</span>
            <span class={`r-proj ${r.kind}`}>{r.proj}</span>
            <span class="r-msg" set:html={r.msg} />
          </div>
        ))}
      </div>
    </section>

    <section class="p-stats">
      <h2 class="p-stats-title">
        <span class="u1">small</span> tools.<br/>
        <span class="u2">big</span> years.
      </h2>
      <div class="p-stats-grid">
        <div class="p-stat">
          <div class="num"><Tally client:visible to={stats.shippingTools} duration={800} /></div>
          <div class="cap">shipping tools</div>
          <span class="accent-mark" />
        </div>
        <div class="p-stat">
          <div class="num"><Tally client:visible to={stats.githubStars} duration={1400} /></div>
          <div class="cap">github stars</div>
          <span class="accent-mark" />
        </div>
        <div class="p-stat">
          <div class="num"><Tally client:visible to={stats.locales} duration={1000} /></div>
          <div class="cap">locales · across tools</div>
          <span class="accent-mark" />
        </div>
        <div class="p-stat">
          <div class="num"><Tally client:visible to={stats.telemetry} duration={600} /></div>
          <div class="cap">zero telemetry</div>
          <span class="accent-mark" />
        </div>
      </div>
    </section>

    <section class="p-manifest">
      <div class="p-manifest-shapes" aria-hidden="true">
        <div class="s1" />
        <div class="s2" />
        <div class="s3" />
      </div>
      <div class="t-small" style="color: var(--yellow); margin-bottom: 18px;">§ 03 · position</div>
      <div class="p-manifest-lines">
        <span class="hl-y">software</span> you can read.<br/>
        tools that <span class="hl-r">don't phone home.</span><br/>
        interfaces that<br/>
        <span class="hl-b">respect your hands.</span>
      </div>
      <div class="p-manifest-sig">
        § snaix.homes · 2023→
      </div>
    </section>

    <footer class="p-foot">
      <div class="p-foot-brand">
        <div class="logo" aria-hidden="true" />
        <div style="margin-top: 12px; font-size: 20px; font-weight: 700; letter-spacing: -0.01em;">snaix.homes</div>
        <div class="t-mono-sm" style="color: var(--steel-5); margin-top: 6px;">small tools. big years.</div>
      </div>
      <div class="p-foot-col">
        <span class="t-small">tools</span>
        <ul>
          {products.map((p) => (
            <li><a href={p.href}>{p.name}</a></li>
          ))}
        </ul>
      </div>
      <div class="p-foot-col">
        <span class="t-small">learn</span>
        <ul>
          <li><a href="/bcmr/docs/getting-started">docs</a></li>
          <li><a href="https://github.com/Bengerthelorf/bcmr/releases">changelog ↗</a></li>
          <li><a href="#">recipes</a></li>
          <li><a href="#">rss</a></li>
        </ul>
      </div>
      <div class="p-foot-col">
        <span class="t-small">elsewhere</span>
        <ul>
          <li><a href="#">github ↗</a></li>
          <li><a href="#">x / twitter ↗</a></li>
          <li><a href="#">discord ↗</a></li>
          <li><a href="#">manifesto</a></li>
        </ul>
      </div>
    </footer>
    <div class="p-foot-base">
      <span>© 2023–{year} snaix · all open source</span>
      <span>{edition} · built {build.date} · sha {build.sha}</span>
    </div>
  </div>
</DefaultLayout>
