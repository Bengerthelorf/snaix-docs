---
import DocsLayout from '@snaix/docs-theme/layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import {
  DEFAULT_LOCALE,
  bareSlug,
  docsBaseFor,
  isDefaultLocaleEntry,
  navFor,
} from '../../../lib/docs.ts';
import { product } from '../../../lib/product.ts';

const claudit = product('claudit');

export async function getStaticPaths() {
  const entries = await getCollection('claudit', isDefaultLocaleEntry);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const all = await getCollection('claudit');
const nav = await navFor(DEFAULT_LOCALE, all, ['guide'], '/claudit/docs');
const { Content, headings } = await entry.render();
const toc = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({ slug: h.slug, text: h.text, depth: h.depth }));

const bare = bareSlug(entry.slug);
const sectionLabel = DEFAULT_LOCALE.ui?.sections?.['guide'] ?? 'guide';
const docsLabel = DEFAULT_LOCALE.ui?.docsLabel ?? 'docs';
---
<DocsLayout
  product={claudit}
  brand={claudit.title}
  version={claudit.version}
  current={bare}
  nav={nav}
  title={entry.data.title}
  description={entry.data.description}
  breadcrumb={[docsLabel, sectionLabel, entry.data.title]}
  toc={toc}
  source={{
    path: `docs/${bare}.md`,
    url: `https://github.com/Bengerthelorf/Claudit/edit/main/docs/${bare}.md`,
  }}
  locale={DEFAULT_LOCALE.code}
  languages={claudit.docsLanguages(entry, all, DEFAULT_LOCALE)}
  docsBase={docsBaseFor(DEFAULT_LOCALE, '/claudit/docs')}
  tocLabel={DEFAULT_LOCALE.ui?.tocLabel ?? 'on this page'}
  topNav={claudit.nav()}
  currentTab="docs"
>
  <Content />
</DocsLayout>
