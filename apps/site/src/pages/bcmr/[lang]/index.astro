---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import {
  BlockReveal,
  Scramble,
  Tally,
  Typewriter,
  CommandStream,
} from '@snaix/docs-theme';
import type { CmdLine } from '@snaix/docs-theme';
import { resolveLocale } from '../../../lib/docs.ts';
import { product } from '../../../lib/product.ts';

export async function getStaticPaths() {
  return ['zh', 'zh-Hant'].map((code) => ({ params: { lang: code } }));
}

const bcmrProduct = product('bcmr');
const locale = resolveLocale(Astro.params.lang!);

const copy = {
  zh: {
    title: 'bcmr — 更好的复制、移动、删除',
    topLine: 'bcmr · 更好的 cp / mv / rm',
    topMid: '本地与 ssh · 同一条命令',
    overview: '§ 01 · 概览',
    eyebrow: '// cp + mv + scp —— 但是诚实的那种。',
    headline: ['复制.', '移动.', '删除.'],
    lede: 'bcmr 是 cp / mv / scp 的现代替代品。每次写入流式 blake3 校验，崩溃后可续传，本地路径和 ssh 路径在同一条命令里 —— 一个命令，两端都校验过。',
    install: '↳ 安装',
    docs: '阅读文档',
    deviceTagVerified: '已校验',
    deviceComment: '# 14.2 gb · 本地 → ssh',
    deviceSrc: '源',
    deviceDst: '目标',
    deviceRate: '速率',
    deviceEta: '剩余',
    deviceHash: '校验',
    deviceFootline: 'direct-tcp · 快速通道',
    ribbon: [
      { n: '01', t: 'blake3 流式校验', d: '每个字节写入时都在两端哈希，--verify 升级为完整的两遍重读。' },
      { n: '02', t: '崩溃后可续传',     d: '杀进程、拔网线，重新执行同一条命令，从上一个已校验的分块继续。' },
      { n: '03', t: '本地 + ssh 一条命令', d: 'bcmr copy a.txt user@host:/b/ 和 bcmr copy a.txt /b/ 是同一个动词。相同的参数，相同的保证。' },
      { n: '04', t: 'reflink · 稀疏 · dedup', d: 'linux 上用 copy_file_range，apfs 上用 clone_file，稀疏文件检测，≥ 16 mib 的内容寻址去重。' },
    ],
    sec2: '§ 02 · 同一条命令',
    sec2Title: ['本地 ssh,', '同一条命令。'],
    sec2Lede: 'cp 和 scp 把本地和远程当成两个世界。bcmr 只当它们是两种路径。bcmr copy 在 3 mb 的本地拷贝和 300 gb 的跨机房传输里是同一条命令。',
    sec3: '§ 03 · 特性',
    sec3Title: ['六件事', '它都做对了。'],
    sec3Lede: '这些是承诺，不是描述。如果你发现任何一条被违反了，那就是我们想听到的 bug。',
    features: [
      { n: '01', t: 'blake3 无处不在',      d: '每个分块都在两端被哈希。只有校验通过的传输，bcmr 才会告诉你成功了。' },
      { n: '02', t: '崩溃 · 续传',          d: '杀进程、拔线、丢 ssh 会话。重新执行同一条命令，bcmr 从上一个已校验的字节继续。' },
      { n: '03', t: '本地 + ssh',           d: '一个动词，两个宇宙。本地路径像 cp，远程路径像 scp。你不必再想「该用哪一个」。' },
      { n: '04', t: 'reflink · 稀疏',       d: 'apfs / btrfs / xfs / zfs 上使用 clone_file / reflink / copy_file_range。100 gb 的拷贝在支持的文件系统上只要毫秒。' },
      { n: '05', t: 'lz4 · zstd · dedup',   d: '可选的线路压缩 lz4 / zstd。内容寻址去重避免发送你已经有过的字节。' },
      { n: '06', t: 'json + tui',           d: '脚本里用 --json，终端里用 --tui。同一个二进制、同一套命令 —— 只是外壳不同。' },
    ],
    metrics: [
      { cap: 'direct-tcp · 峰值' },
      { cap: 'blake3 覆盖率' },
      { cap: '支持的平台数' },
      { cap: '遥测 · 永远' },
    ],
    sec4: '§ 04 · 开始',
    sec4Headline: ['一个动词。', '已校验。', '可续传。'],
    installBig: '安装 bcmr ↳',
    readDocs: '阅读文档',
    license: 'mit 授权 · 无遥测 · 自 2024 年开源',
  },
  'zh-Hant': {
    title: 'bcmr — 更好的複製、移動、刪除',
    topLine: 'bcmr · 更好的 cp / mv / rm',
    topMid: '本地與 ssh · 同一條指令',
    overview: '§ 01 · 概覽',
    eyebrow: '// cp + mv + scp —— 但是誠實的那種。',
    headline: ['複製.', '移動.', '刪除.'],
    lede: 'bcmr 是 cp / mv / scp 的現代替代品。每次寫入串流式 blake3 校驗，崩潰後可續傳，本地路徑和 ssh 路徑在同一條指令裡 —— 一個指令，兩端都校驗過。',
    install: '↳ 安裝',
    docs: '閱讀文件',
    deviceTagVerified: '已校驗',
    deviceComment: '# 14.2 gb · 本地 → ssh',
    deviceSrc: '來源',
    deviceDst: '目的',
    deviceRate: '速率',
    deviceEta: '剩餘',
    deviceHash: '校驗',
    deviceFootline: 'direct-tcp · 快速通道',
    ribbon: [
      { n: '01', t: 'blake3 串流校驗', d: '每個位元組寫入時都在兩端雜湊，--verify 升級為完整的兩遍重讀。' },
      { n: '02', t: '崩潰後可續傳',     d: '砍行程、拔網線，再執行同一條指令，從上一個已校驗的區塊繼續。' },
      { n: '03', t: '本地 + ssh 一條指令', d: 'bcmr copy a.txt user@host:/b/ 和 bcmr copy a.txt /b/ 是同一個動詞。相同的參數，相同的保證。' },
      { n: '04', t: 'reflink · 稀疏 · dedup', d: 'linux 上使用 copy_file_range，apfs 上使用 clone_file，稀疏檔案偵測，≥ 16 mib 的內容定址去重。' },
    ],
    sec2: '§ 02 · 同一條指令',
    sec2Title: ['本地 ssh,', '同一條指令。'],
    sec2Lede: 'cp 和 scp 把本地與遠端當成兩個世界。bcmr 只當它們是兩種路徑。bcmr copy 在 3 mb 的本地拷貝和 300 gb 的跨機房傳輸裡是同一條指令。',
    sec3: '§ 03 · 特性',
    sec3Title: ['六件事', '它都做對了。'],
    sec3Lede: '這些是承諾，不是描述。如果你發現任何一條被違反了，那就是我們想聽到的 bug。',
    features: [
      { n: '01', t: 'blake3 無處不在',      d: '每個區塊都在兩端被雜湊。只有校驗通過的傳輸，bcmr 才會告訴你成功了。' },
      { n: '02', t: '崩潰 · 續傳',          d: '砍行程、拔線、掉 ssh 連線。再執行同一條指令，bcmr 從上一個已校驗的位元組繼續。' },
      { n: '03', t: '本地 + ssh',           d: '一個動詞，兩個宇宙。本地路徑像 cp，遠端路徑像 scp。你不必再想「該用哪一個」。' },
      { n: '04', t: 'reflink · 稀疏',       d: 'apfs / btrfs / xfs / zfs 上使用 clone_file / reflink / copy_file_range。100 gb 的拷貝在支援的檔案系統上只要毫秒。' },
      { n: '05', t: 'lz4 · zstd · dedup',   d: '可選的線路壓縮 lz4 / zstd。內容定址去重避免傳送你已經有過的位元組。' },
      { n: '06', t: 'json + tui',           d: '腳本裡用 --json，終端裡用 --tui。同一個二進位檔、同一套指令 —— 只是外殼不同。' },
    ],
    metrics: [
      { cap: 'direct-tcp · 峰值' },
      { cap: 'blake3 覆蓋率' },
      { cap: '支援的平台數' },
      { cap: '遙測 · 永遠' },
    ],
    sec4: '§ 04 · 開始',
    sec4Headline: ['一個動詞。', '已校驗。', '可續傳。'],
    installBig: '安裝 bcmr ↳',
    readDocs: '閱讀文件',
    license: 'mit 授權 · 無遙測 · 自 2024 年開源',
  },
} as const;

const t = copy[locale.code as 'zh' | 'zh-Hant'];

const terminalScript: CmdLine[] = locale.code === 'zh' ? [
  { type: 'prompt', text: 'bcmr copy ./dataset user@node-04:/srv/' },
  { type: 'out',    text: '扫描源 …… 2,481 个文件 · 14.2 gb', pause: 200 },
  { type: 'out',    text: 'ssh 握手 …… ok', pause: 140 },
  { type: 'out',    text: 'direct-tcp 快速通道 …… 已协商', pause: 180 },
  { type: 'ok',     text: '完成 · 34.5s · 412 mb/s · 全部 blake3 已校验', pause: 260 },
  { type: 'blank' },
  { type: 'prompt', text: 'bcmr copy -C ./big.iso user@node-04:/iso/', pause: 320 },
  { type: 'out',    text: '发现未完成传输 —— 从第 4,298,571,264 字节恢复', pause: 180 },
  { type: 'ok',     text: '完成 · 12.1s · 哈希匹配', pause: 160 },
] : [
  { type: 'prompt', text: 'bcmr copy ./dataset user@node-04:/srv/' },
  { type: 'out',    text: '掃描來源 …… 2,481 個檔案 · 14.2 gb', pause: 200 },
  { type: 'out',    text: 'ssh 握手 …… ok', pause: 140 },
  { type: 'out',    text: 'direct-tcp 快速通道 …… 已協商', pause: 180 },
  { type: 'ok',     text: '完成 · 34.5s · 412 mb/s · 全部 blake3 已校驗', pause: 260 },
  { type: 'blank' },
  { type: 'prompt', text: 'bcmr copy -C ./big.iso user@node-04:/iso/', pause: 320 },
  { type: 'out',    text: '發現未完成傳輸 —— 從第 4,298,571,264 位元組繼續', pause: 180 },
  { type: 'ok',     text: '完成 · 12.1s · 雜湊相符', pause: 160 },
];
---
<DefaultLayout title={t.title} lang={locale.lang ?? locale.code}>
  <div class="page home">
    <TopBar
      brand={bcmrProduct.title}
      version={bcmrProduct.version}
      current="home"
      showStatus={false}
      githubHref={bcmrProduct.githubUrl}
      nav={bcmrProduct.nav()}
    />

    <section class="hero">
      <div class="hero-top rule-b">
        <span class="t-mono-sm">{t.topLine}</span>
        <span class="t-mono-sm">{t.topMid}</span>
        <span class="t-mono-sm">{bcmrProduct.version} · {bcmrProduct.releaseDate}</span>
      </div>

      <div class="hero-grid grid12">
        <div class="hero-headline">
          <div class="hero-eyebrow">
            <span class="t-small">{t.overview}</span>
            <span class="t-mono-sm" style="color: var(--steel-5);">
              <Typewriter client:visible text={t.eyebrow} speed={24} delay={300} />
            </span>
          </div>
          <h1 class="t-display lower">
            <span class="hl-line"><BlockReveal client:visible delay={400} duration={520}>{t.headline[0]}</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:visible delay={760} duration={520} color="var(--red)">{t.headline[1]}</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:visible delay={1120} duration={520} color="var(--blue)">{t.headline[2]}</BlockReveal></span>
          </h1>

          <p class="hero-lede">{t.lede}</p>

          <div class="hero-cta">
            <a class="btn-block" href={bcmrProduct.href(`/${locale.code}/install`)}>{t.install} {bcmrProduct.version}</a>
            <a class="btn-block is-ghost" href={bcmrProduct.href(`/${locale.code}/docs/getting-started`)}>{t.docs}</a>
            <span class="hero-cta-meta t-mono-sm">
              ⌘ <span>brew install Bengerthelorf/tap/bcmr</span>
            </span>
          </div>
        </div>

        <aside class="hero-device">
          <div class="device-head">
            <div class="t-small">transfer.live</div>
            <div class="chip is-blue"><span class="dot"/>{t.deviceTagVerified}</div>
          </div>
          <div style="padding: 16px; background: var(--c-ink-0); color: var(--c-paper-pure); font-family: var(--mono); font-size: 12px; line-height: 1.7;">
            <div style="color: var(--c-steel-5);">{t.deviceComment}</div>
            <div>{t.deviceSrc}  <b style="color: var(--c-paper-pure);">./dataset/</b></div>
            <div>{t.deviceDst} <b style="color: var(--c-paper-pure);">node-04:/srv/</b></div>
            <div style="margin: 10px 0; color: var(--c-steel-3);">────────────────</div>
            <div>{t.deviceRate} <span style="color: var(--c-yellow);"><Tally client:visible to={412} duration={900} suffix=" mb/s" /></span></div>
            <div>{t.deviceEta} <span style="color: var(--c-yellow);">00:00:12</span></div>
            <div>{t.deviceHash} <span style="color: var(--c-blue-dim);">blake3</span> ok</div>
            <div style="margin-top: 10px; background: var(--c-steel-9); height: 6px; position: relative; overflow: hidden;">
              <div style="position: absolute; inset: 0; right: 18%; background: var(--c-blue-dim);" />
            </div>
            <div style="margin-top: 6px; display: flex; justify-content: space-between; color: var(--c-steel-5);">
              <span>82%</span><span>11.6 / 14.2 gb</span>
            </div>
          </div>
          <div class="device-footline">
            <span class="t-mono-sm">{t.deviceFootline}</span>
            <span class="t-mono-sm" style="color: var(--blue);">● live</span>
          </div>
        </aside>
      </div>

      <div class="hero-ribbon rule-t">
        {t.ribbon.map((r, i) => (
          <div class="ribbon-item">
            <div class="ribbon-head">
              <span class="t-small">{r.n}</span>
              <span class="ribbon-label"><Scramble client:visible text={r.t} delay={200 + i * 150} /></span>
            </div>
            <div class="ribbon-sub">{r.d}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="home-section">
      <div class="section-head">
        <div class="section-head-left">
          <div class="t-small">{t.sec2}</div>
          <h2 class="t-h1 lower">{t.sec2Title[0]}<br/>{t.sec2Title[1]}</h2>
        </div>
        <div class="section-head-right">
          <p class="t-body">{t.sec2Lede}</p>
        </div>
      </div>

      <div class="terminal-shell">
        <div class="terminal-chrome">
          <div class="terminal-lights"><span/><span/><span/></div>
          <div class="t-mono-sm">zsh · {bcmrProduct.title} {String(bcmrProduct.version ?? '').replace(/^v/, '')}</div>
          <div class="t-mono-sm" style="color: var(--steel-5);">~/work</div>
        </div>
        <div class="terminal-body">
          <CommandStream client:visible lines={terminalScript} />
        </div>
      </div>
    </section>

    <section class="home-section home-principles">
      <div class="section-head">
        <div class="section-head-left">
          <div class="t-small">{t.sec3}</div>
          <h2 class="t-h1 lower">{t.sec3Title[0]}<br/>{t.sec3Title[1]}</h2>
        </div>
        <div class="section-head-right">
          <p class="t-body">{t.sec3Lede}</p>
        </div>
      </div>

      <div class="principles-grid">
        {t.features.map((it, i) => {
          const marks = ['sq', 'ci', 'tr', 'sq', 'ci', 'tr'] as const;
          const colors = ['var(--ink)', 'var(--red)', 'var(--blue)', 'var(--yellow)', 'var(--ink)', 'var(--red)'];
          const mark = marks[i];
          const color = colors[i];
          return (
            <div class="principle">
              <div class="principle-n t-mono">{it.n}</div>
              <div class="principle-title t-h3 lower">{it.t}</div>
              <div class="principle-d">{it.d}</div>
              <div class="principle-mark">
                {mark === 'sq' && <div style={`width: 14px; height: 14px; background: ${color};`} />}
                {mark === 'ci' && <div style={`width: 14px; height: 14px; border-radius: 50%; background: ${color};`} />}
                {mark === 'tr' && <div style={`width: 0; height: 0; border-left: 8px solid transparent; border-right: 8px solid transparent; border-bottom: 14px solid ${color};`} />}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="home-section home-metrics">
      <div class="metrics-strip">
        <div class="metric">
          <div class="metric-num t-display"><Tally client:visible to={412} suffix=" mb/s" duration={1100} /></div>
          <div class="metric-cap t-small">{t.metrics[0].cap}</div>
        </div>
        <div class="metric">
          <div class="metric-num t-display"><Tally client:visible to={100} suffix="%" duration={1000} /></div>
          <div class="metric-cap t-small">{t.metrics[1].cap}</div>
        </div>
        <div class="metric">
          <div class="metric-num t-display"><Tally client:visible to={4} duration={800} /></div>
          <div class="metric-cap t-small">{t.metrics[2].cap}</div>
        </div>
        <div class="metric">
          <div class="metric-num t-display"><Tally client:visible to={0} duration={600} /><span style="font-size: 0.5em; vertical-align: super; margin-left: 6px;">kb</span></div>
          <div class="metric-cap t-small">{t.metrics[3].cap}</div>
        </div>
      </div>
    </section>

    <section class="home-cta">
      <div class="cta-inner">
        <div class="t-small" style="color: var(--c-steel-3);">{t.sec4}</div>
        <h2 class="t-display lower" style="color: var(--c-paper-pure);">
          <BlockReveal client:visible delay={200} color="var(--yellow)">{t.sec4Headline[0]}</BlockReveal><br/>
          <BlockReveal client:visible delay={700} color="var(--red)">{t.sec4Headline[1]}</BlockReveal><br/>
          <BlockReveal client:visible delay={1200} color="var(--blue)">{t.sec4Headline[2]}</BlockReveal>
        </h2>
        <div class="cta-buttons">
          <a class="btn-block" style="background: var(--c-paper-pure); color: var(--c-ink-0); border-color: var(--c-paper-pure);" href={bcmrProduct.href(`/${locale.code}/install`)}>
            {t.installBig}
          </a>
          <a class="btn-block" style="background: transparent; color: var(--c-paper-pure); border-color: var(--c-paper-pure);" href={bcmrProduct.href(`/${locale.code}/docs/getting-started`)}>
            {t.readDocs}
          </a>
        </div>
        <div class="cta-small t-mono-sm">{t.license}</div>
      </div>
    </section>

    <Footer product={bcmrProduct} locale={locale.code} languages={bcmrProduct.pageLanguages(locale.code, '/', ['en', 'zh', 'zh-Hant'])} />
  </div>
</DefaultLayout>
