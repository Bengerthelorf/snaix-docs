---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import ReleasesList from '../../components/ReleasesList.astro';
import { fetchReleases } from '../../data/fetch-github.ts';
import { product } from '../../lib/product.ts';

const bcmr = product('bcmr');
const releases = await fetchReleases(bcmr.repo, 30);
---
<DefaultLayout title={`${bcmr.title} · changelog`}>
  <div class="page changelog">
    <TopBar
      brand={bcmr.title}
      version={bcmr.version}
      current="changelog"
      githubHref={bcmr.githubUrl}
      nav={bcmr.nav()}
    />

    <section class="log-hero">
      <div class="t-small" style="color: var(--red);">§ changelog</div>
      <h1 class="install-title lower" style="margin-top: 8px;">what changed.</h1>
      <p class="t-body" style="margin-top: 16px; max-width: 640px;">
        every release published on github, mirrored here verbatim from the
        release notes. newest first.
      </p>
    </section>

    <ReleasesList releases={releases} repo={bcmr.repo} />

    <Footer product={bcmr} locale="en" languages={bcmr.pageLanguages('en', '/changelog', ['en'])} />
  </div>
</DefaultLayout>
