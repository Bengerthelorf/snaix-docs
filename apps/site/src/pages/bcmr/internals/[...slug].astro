---
import DocsLayout from '@snaix/docs-theme/layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import {
  DEFAULT_LOCALE,
  docsBaseFor,
  navFor,
} from '../../../lib/docs.ts';
import { product } from '../../../lib/product.ts';

const bcmrProduct = product('bcmr');

export async function getStaticPaths() {
  const entries = await getCollection('bcmr', (e) => (e.data.section ?? 'guide') === 'internals');
  return entries.map((entry) => {
    const tail = entry.slug.replace(/^ablation\/?/, '');
    return {
      params: { slug: tail === '' ? undefined : tail },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const all = await getCollection('bcmr');
const nav = await navFor(DEFAULT_LOCALE, all, ['internals'], { internalsDocsRoot: '/bcmr/internals' });
const languages = bcmrProduct.docsLanguages(entry, all, DEFAULT_LOCALE, '/internals');
const { Content, headings } = await entry.render();
const toc = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({ slug: h.slug, text: h.text, depth: h.depth }));

const bare = entry.slug.replace(/^ablation\/?/, '') || 'index';
const docsLabel = DEFAULT_LOCALE.ui?.docsLabel ?? 'docs';
const breadcrumb = [docsLabel, 'internals', entry.data.title];
---
<DocsLayout
  product={bcmrProduct}
  brand={bcmrProduct.title}
  version={bcmrProduct.version}
  current={bare}
  nav={nav}
  title={entry.data.title}
  description={entry.data.description}
  breadcrumb={breadcrumb}
  toc={toc}
  source={{
    path: `docs/ablation/${bare}.md`,
    url: `https://github.com/Bengerthelorf/bcmr/edit/main/docs/ablation/${bare}.md`,
  }}
  locale={DEFAULT_LOCALE.code}
  languages={languages}
  docsBase={docsBaseFor(DEFAULT_LOCALE, '/bcmr/internals')}
  tocLabel={DEFAULT_LOCALE.ui?.tocLabel ?? 'on this page'}
  math={true}
  mermaid={true}
  topNav={bcmrProduct.nav()}
  currentTab="internals"
>
  <Content />
</DocsLayout>
