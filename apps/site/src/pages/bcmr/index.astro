---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import {
  BlockReveal,
  Scramble,
  Tally,
  Typewriter,
  CommandStream,
  withBase,
} from '@snaix/docs-theme';
import type { CmdLine } from '@snaix/docs-theme';
import { snaixConfig } from 'virtual:snaix-config';
import { DEFAULT_LOCALE, topNavFor, localesAsLanguages } from '../../lib/docs.ts';
import { product } from '../../lib/product.ts';

const bcmrProduct = product('bcmr');

const languages = localesAsLanguages('en', '/');

const terminalScript: CmdLine[] = [
  { type: 'prompt', text: 'bcmr copy ./dataset user@node-04:/srv/' },
  { type: 'out',    text: 'scanning …… 2,481 files · 14.2 gb', pause: 200 },
  { type: 'out',    text: 'handshake (ssh) …… ok', pause: 140 },
  { type: 'out',    text: 'direct-tcp fast path …… negotiated', pause: 180 },
  { type: 'ok',     text: 'complete · 34.5s · 412 mb/s · all blake3 verified', pause: 260 },
  { type: 'blank' },
  { type: 'prompt', text: 'bcmr copy -C ./big.iso user@node-04:/iso/', pause: 320 },
  { type: 'out',    text: 'found partial — resuming from byte 4,298,571,264', pause: 180 },
  { type: 'ok',     text: 'complete · 12.1s · hashes match', pause: 160 },
];

const features = [
  { n: '01', t: 'integrity by default',   d: 'every copy streams through blake3 during the write. --verify promotes that to a full 2-pass checksum round-trip — not an opt-in rescan like rsync\'s --checksum.',      mark: 'sq', color: 'var(--ink)' },
  { n: '02', t: 'crash-safe resume',      d: 'interrupt a bcmr copy and run the same command again — session file, tail-block verify, continue where it stopped. no --partial --append-verify incantation.',         mark: 'ci', color: 'var(--red)' },
  { n: '03', t: 'one cli, local or ssh',  d: 'bcmr copy a.txt /b/ and bcmr copy a.txt user@host:/b/ are the same command with the same flags. no cp/scp/rsync context switch.',                                      mark: 'tr', color: 'var(--blue)' },
  { n: '04', t: 'direct-tcp fast path',   d: 'optional aes-256-gcm data plane over direct tcp bypasses ssh\'s single-stream crypto ceiling on lan. keys negotiated via the ssh control channel.',                    mark: 'sq', color: 'var(--yellow)' },
  { n: '05', t: 'fast by default',        d: 'reflink (copy-on-write), copy_file_range on linux, sparse file detection, and pipeline scan+copy for immediate start.',                                                mark: 'ci', color: 'var(--ink)' },
  { n: '06', t: 'safe by default',        d: 'atomic writes via temp file + rename, durable fsync (F_FULLFSYNC on macos), dry-run preview, and regex exclusions.',                                                   mark: 'tr', color: 'var(--red)' },
  { n: '07', t: 'built for humans + agents', d: 'tui with per-file progress for humans. --json detaches to a background job streaming ndjson; bcmr status <id> returns state. survives terminal close.',             mark: 'sq', color: 'var(--blue)' },
  { n: '08', t: 'wire compression + dedup',  d: 'per-block lz4/zstd negotiated in the serve handshake (~5× on source text), plus content-addressed dedup for repeat uploads ≥ 16 mib.',                              mark: 'ci', color: 'var(--yellow)' },
] as const;
---
<DefaultLayout title="bcmr — better copy move remove">
  <div class="page home">
    <TopBar
      brand="bcmr"
      version={snaixConfig.version}
      current="home"
      logoVariant="product"
      showStatus={false}
      githubHref={snaixConfig.githubUrl}
      nav={topNavFor(DEFAULT_LOCALE)}
    />

    <section class="hero">
      <div class="hero-top rule-b">
        <span class="t-mono-sm">bcmr / better copy move remove</span>
        <span class="t-mono-sm">one verb for local + ssh</span>
        <span class="t-mono-sm">{snaixConfig.version} · {snaixConfig.releaseDate}</span>
      </div>

      <div class="hero-grid grid12">
        <div class="hero-headline">
          <div class="hero-eyebrow">
            <span class="t-small">§ 01 · overview</span>
            <span class="t-mono-sm" style="color: var(--steel-5);">
              <Typewriter client:load text="// cp + mv + scp · verified end-to-end." speed={24} delay={300} />
            </span>
          </div>
          <h1 class="t-display lower">
            <span class="hl-line"><BlockReveal client:load delay={400} duration={520}>copy.</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:load delay={760} duration={520} color="var(--red)">move.</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:load delay={1120} duration={520} color="var(--blue)">remove.</BlockReveal></span>
          </h1>

          <p class="hero-lede">
            a modern replacement for cp, mv, and scp. blake3 checksums streamed during every write.
            crash-safe resume. one cli for local paths and ssh paths — same flags, same guarantees.
          </p>

          <div class="hero-cta">
            <a class="btn-block" href={withBase('/install')}>↳ install {snaixConfig.version}</a>
            <a class="btn-block is-ghost" href={withBase('/docs/getting-started')}>read the docs</a>
            <span class="hero-cta-meta t-mono-sm">
              ⌘ <span>brew install Bengerthelorf/tap/bcmr</span>
            </span>
          </div>
        </div>

        <aside class="hero-device">
          <div class="device-head">
            <div class="t-small">transfer.live</div>
            <div class="chip is-blue"><span class="dot"/>verified</div>
          </div>
          <div style="padding: 16px; background: var(--ink); color: var(--paper-pure); font-family: var(--mono); font-size: 12px; line-height: 1.7;">
            <div style="color: var(--steel-5);"># 14.2 gb · local → ssh</div>
            <div>src  <b style="color: var(--paper-pure);">./dataset/</b></div>
            <div>dst  <b style="color: var(--paper-pure);">node-04:/srv/</b></div>
            <div style="margin: 10px 0; color: var(--steel-3);">────────────────</div>
            <div>rate <span style="color: var(--yellow);"><Tally client:load to={412} duration={900} suffix=" mb/s" /></span></div>
            <div>eta  <span style="color: var(--yellow);">00:00:12</span></div>
            <div>hash <span style="color: var(--blue);">blake3</span> ok</div>
            <div style="margin-top: 10px; background: var(--steel-9); height: 6px; position: relative; overflow: hidden;">
              <div style="position: absolute; inset: 0; right: 18%; background: var(--blue);" />
            </div>
            <div style="margin-top: 6px; display: flex; justify-content: space-between; color: var(--steel-5);">
              <span>82%</span><span>11.6 / 14.2 gb</span>
            </div>
          </div>
          <div class="device-footline">
            <span class="t-mono-sm">direct-tcp · fast path</span>
            <span class="t-mono-sm" style="color: var(--blue);">● live</span>
          </div>
        </aside>
      </div>

      <div class="hero-ribbon rule-t">
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">01</span>
            <span class="ribbon-label"><Scramble client:load text="blake3 streamed" delay={200} /></span>
          </div>
          <div class="ribbon-sub">every byte hashed on both ends as it's written. --verify promotes it to a full 2-pass re-read.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">02</span>
            <span class="ribbon-label"><Scramble client:load text="crash-safe resume" delay={350} /></span>
          </div>
          <div class="ribbon-sub">kill the process, pull the cable. rerun the same command. pick up from the last verified chunk.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">03</span>
            <span class="ribbon-label"><Scramble client:load text="local + ssh · one cli" delay={500} /></span>
          </div>
          <div class="ribbon-sub">bcmr copy a.txt user@host:/b/ is the same verb as bcmr copy a.txt /b/. same flags, same guarantees.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">04</span>
            <span class="ribbon-label"><Scramble client:load text="reflink · sparse · dedup" delay={650} /></span>
          </div>
          <div class="ribbon-sub">copy_file_range on linux, clone_file on apfs, sparse file detection, content-addressed dedup ≥ 16 mib.</div>
        </div>
      </div>
    </section>

    <section class="home-section">
      <div class="section-head">
        <div class="section-head-left">
          <div class="t-small">§ 02 · one cli</div>
          <h2 class="t-h1 lower">local, ssh,<br/>same command.</h2>
        </div>
        <div class="section-head-right">
          <p class="t-body">
            cp and scp treat local and remote as two different universes.
            bcmr treats them as two different paths. <code class="inline-code">bcmr copy</code> works
            the same way whether you are moving 3 mb across a disk or
            300 gb across a datacenter.
          </p>
        </div>
      </div>

      <div class="terminal-shell">
        <div class="terminal-chrome">
          <div class="terminal-lights"><span/><span/><span/></div>
          <div class="t-mono-sm">zsh · {snaixConfig.title} {String(snaixConfig.version ?? '').replace(/^v/, '')}</div>
          <div class="t-mono-sm" style="color: var(--steel-5);">~/work</div>
        </div>
        <div class="terminal-body">
          <CommandStream client:load lines={terminalScript} />
        </div>
      </div>
    </section>

    <section class="home-section home-principles">
      <div class="section-head">
        <div class="section-head-left">
          <div class="t-small">§ 03 · features</div>
          <h2 class="t-h1 lower">eight things<br/>it does right.</h2>
        </div>
        <div class="section-head-right">
          <p class="t-body">
            these are promises, not descriptions. if you find one violated,
            that is a bug we want to hear about.
          </p>
        </div>
      </div>

      <div class="principles-grid">
        {features.map((it) => (
          <div class="principle">
            <div class="principle-n t-mono">{it.n}</div>
            <div class="principle-title t-h3 lower">{it.t}</div>
            <div class="principle-d">{it.d}</div>
            <div class="principle-mark">
              {it.mark === 'sq' && <div style={`width: 14px; height: 14px; background: ${it.color};`} />}
              {it.mark === 'ci' && <div style={`width: 14px; height: 14px; border-radius: 50%; background: ${it.color};`} />}
              {it.mark === 'tr' && <div style={`width: 0; height: 0; border-left: 8px solid transparent; border-right: 8px solid transparent; border-bottom: 14px solid ${it.color};`} />}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="home-cta">
      <div class="cta-inner">
        <div class="t-small" style="color: var(--steel-3);">§ 04 · begin</div>
        <h2 class="t-display lower" style="color: var(--paper-pure);">
          <BlockReveal client:load delay={200} color="var(--yellow)">one cli.</BlockReveal><br/>
          <BlockReveal client:load delay={700} color="var(--red)">verified.</BlockReveal><br/>
          <BlockReveal client:load delay={1200} color="var(--blue)">resumable.</BlockReveal>
        </h2>
        <div class="cta-buttons">
          <a class="btn-block" style="background: var(--paper-pure); color: var(--ink); border-color: var(--paper-pure);" href={withBase('/docs/getting-started')}>
            get started ↳
          </a>
          <a class="btn-block" style="background: transparent; color: var(--paper-pure); border-color: var(--paper-pure);" href={withBase('/docs/cli/commands')}>
            cli reference
          </a>
        </div>
        <div class="cta-small t-mono-sm">
          apache-2.0 licensed · no telemetry · open source
        </div>
      </div>
    </section>

    <Footer product={bcmrProduct} locale="en" languages={languages} />
  </div>
</DefaultLayout>
