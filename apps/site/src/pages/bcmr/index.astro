---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import {
  BlockReveal,
  Scramble,
  Tally,
  Typewriter,
  CommandStream,
} from '@snaix/docs-theme';
import type { CmdLine } from '@snaix/docs-theme';
import { product } from '../../lib/product.ts';

const bcmrProduct = product('bcmr');

const terminalScript: CmdLine[] = [
  { type: 'prompt', text: 'bcmr copy ./dataset user@node-04:/srv/' },
  { type: 'out',    text: 'scanning …… 2,481 files · 14.2 gb', pause: 200 },
  { type: 'out',    text: 'handshake (ssh) …… ok', pause: 140 },
  { type: 'out',    text: 'direct-tcp fast path …… 6 workers negotiated', pause: 180 },
  { type: 'ok',     text: 'complete · all blake3 verified', pause: 260 },
  { type: 'blank' },
  { type: 'prompt', text: 'bcmr copy -C ./big.iso user@node-04:/iso/', pause: 320 },
  { type: 'out',    text: 'found partial — resuming from byte 4,298,571,264', pause: 180 },
  { type: 'ok',     text: 'complete · tail-block verified · hashes match', pause: 160 },
];

const features = [
  { n: '01', t: 'blake3 everywhere',  d: 'every chunk is hashed on both ends. a verified transfer is the only kind of transfer bcmr will tell you succeeded.',                                    mark: 'sq', color: 'var(--ink)' },
  { n: '02', t: 'crash · resume',     d: 'kill the process, pull the cable, lose the ssh session. run the same command again and bcmr picks up at the last verified byte.',                      mark: 'ci', color: 'var(--red)' },
  { n: '03', t: 'local + ssh',        d: 'one verb, two universes. paths look like cp. remote paths look like scp. no mental tax for which tool to reach for.',                                  mark: 'tr', color: 'var(--blue)' },
  { n: '04', t: 'reflink · sparse',   d: 'on apfs, btrfs, xfs and zfs, bcmr uses clone_file / reflink / copy_file_range. a 100 gb copy takes milliseconds if the fs supports it.',                mark: 'sq', color: 'var(--yellow)' },
  { n: '05', t: 'lz4 · zstd · dedup', d: 'optional on-the-wire compression with lz4 or zstd. content-addressed dedup avoids sending bytes you already have.',                                     mark: 'ci', color: 'var(--ink)' },
  { n: '06', t: 'json + tui',         d: 'use it in a script with --json. use it in a terminal with --tui. same binary. same commands. different skins.',                                         mark: 'tr', color: 'var(--red)' },
] as const;
---
<DefaultLayout title="bcmr — better copy move remove">
  <div class="page home">
    <TopBar
      brand={bcmrProduct.title}
      version={bcmrProduct.version}
      current="home"
      githubHref={bcmrProduct.githubUrl}
      nav={bcmrProduct.nav()}
    />

    <section class="hero">
      <div class="hero-top rule-b">
        <span class="t-mono-sm">bcmr / better copy move remove</span>
        <span class="t-mono-sm">one verb for local + ssh</span>
        <span class="t-mono-sm">{bcmrProduct.version} · {bcmrProduct.releaseDate}</span>
      </div>

      <div class="hero-grid grid12">
        <div class="hero-headline">
          <div class="hero-eyebrow">
            <span class="t-small">§ 01 · overview</span>
            <span class="t-mono-sm" style="color: var(--steel-5);">
              <Typewriter client:visible text="// cp + mv + scp · verified end-to-end." speed={24} delay={300} />
            </span>
          </div>
          <h1 class="t-display lower">
            <span class="hl-line"><BlockReveal client:visible delay={400} duration={520}>copy.</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:visible delay={760} duration={520} color="var(--red)">move.</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:visible delay={1120} duration={520} color="var(--blue)">remove.</BlockReveal></span>
          </h1>

          <p class="hero-lede">
            a modern replacement for cp, mv, and scp. blake3 checksums streamed during every write.
            crash-safe resume. one cli for local paths and ssh paths — same flags, same guarantees.
          </p>

          <div class="hero-cta">
            <a class="btn-block" href={bcmrProduct.href('/install')}>↳ install {bcmrProduct.version}</a>
            <a class="btn-block is-ghost" href={bcmrProduct.href('/docs/getting-started')}>read the docs</a>
            <span class="hero-cta-meta t-mono-sm">
              ⌘ <span>brew install Bengerthelorf/tap/bcmr</span>
            </span>
          </div>
        </div>

        <aside class="hero-device">
          <div class="device-head">
            <div class="t-small">transfer · example</div>
            <div class="chip is-blue"><span class="dot"/>verified</div>
          </div>
          <div style="padding: 16px; background: var(--c-ink-0); color: var(--c-paper-pure); font-family: var(--mono); font-size: 12px; line-height: 1.7;">
            <div style="color: var(--c-steel-5);"># 14.2 gb · local → ssh</div>
            <div>src  <b style="color: var(--c-paper-pure);">./dataset/</b></div>
            <div>dst  <b style="color: var(--c-paper-pure);">node-04:/srv/</b></div>
            <div style="margin: 10px 0; color: var(--c-steel-3);">────────────────</div>
            <div>hash <span style="color: var(--c-blue-dim);">blake3</span> · verified</div>
            <div>mode <span style="color: var(--c-yellow);">resumable</span> · zstd-3</div>
            <div>conn direct-tcp · <span style="color: var(--c-yellow);"><Tally client:visible to={6} duration={700} /></span> worker</div>
            <div style="margin-top: 10px; background: var(--c-steel-9); height: 6px; position: relative; overflow: hidden;">
              <div style="position: absolute; inset: 0; right: 18%; background: var(--c-blue-dim);" />
            </div>
            <div style="margin-top: 6px; display: flex; justify-content: space-between; color: var(--c-steel-5);">
              <span>82%</span><span>11.6 / 14.2 gb</span>
            </div>
          </div>
          <div class="device-footline">
            <span class="t-mono-sm">direct-tcp · fast path</span>
            <span class="t-mono-sm" style="color: var(--blue);">● demo</span>
          </div>
        </aside>
      </div>

      <div class="hero-ribbon rule-t">
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">01</span>
            <span class="ribbon-label"><Scramble client:visible text="blake3 streamed" delay={200} /></span>
          </div>
          <div class="ribbon-sub">every byte hashed on both ends as it's written. --verify promotes it to a full 2-pass re-read.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">02</span>
            <span class="ribbon-label"><Scramble client:visible text="crash-safe resume" delay={350} /></span>
          </div>
          <div class="ribbon-sub">kill the process, pull the cable. rerun the same command. pick up from the last verified chunk.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">03</span>
            <span class="ribbon-label"><Scramble client:visible text="local + ssh · one cli" delay={500} /></span>
          </div>
          <div class="ribbon-sub">bcmr copy a.txt user@host:/b/ is the same verb as bcmr copy a.txt /b/. same flags, same guarantees.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">04</span>
            <span class="ribbon-label"><Scramble client:visible text="reflink · sparse · dedup" delay={650} /></span>
          </div>
          <div class="ribbon-sub">copy_file_range on linux, clone_file on apfs, sparse file detection, content-addressed dedup ≥ 16 mib.</div>
        </div>
      </div>
    </section>

    <section class="home-section">
      <div class="section-head">
        <div class="section-head-left">
          <div class="t-small">§ 02 · one cli</div>
          <h2 class="t-h1 lower">local, ssh,<br/>same command.</h2>
        </div>
        <div class="section-head-right">
          <p class="t-body">
            cp and scp treat local and remote as two different universes.
            bcmr treats them as two different paths. <code class="inline-code">bcmr copy</code> works
            the same way whether you are moving 3 mb across a disk or
            300 gb across a datacenter.
          </p>
        </div>
      </div>

      <div class="terminal-shell">
        <div class="terminal-chrome">
          <div class="terminal-lights"><span/><span/><span/></div>
          <div class="t-mono-sm">zsh · {bcmrProduct.title} {String(bcmrProduct.version ?? '').replace(/^v/, '')}</div>
          <div class="t-mono-sm" style="color: var(--steel-5);">~/work</div>
        </div>
        <div class="terminal-body">
          <CommandStream client:visible lines={terminalScript} />
        </div>
      </div>
    </section>

    <section class="home-section home-principles">
      <div class="section-head">
        <div class="section-head-left">
          <div class="t-small">§ 03 · features</div>
          <h2 class="t-h1 lower">six things<br/>it does right.</h2>
        </div>
        <div class="section-head-right">
          <p class="t-body">
            these are promises, not descriptions. if you find one violated,
            that is a bug we want to hear about.
          </p>
        </div>
      </div>

      <div class="principles-grid">
        {features.map((it) => (
          <div class="principle">
            <div class="principle-n t-mono">{it.n}</div>
            <div class="principle-title t-h3 lower">{it.t}</div>
            <div class="principle-d">{it.d}</div>
            <div class="principle-mark">
              {it.mark === 'sq' && <div style={`width: 14px; height: 14px; background: ${it.color};`} />}
              {it.mark === 'ci' && <div style={`width: 14px; height: 14px; border-radius: 50%; background: ${it.color};`} />}
              {it.mark === 'tr' && <div style={`width: 0; height: 0; border-left: 8px solid transparent; border-right: 8px solid transparent; border-bottom: 14px solid ${it.color};`} />}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="home-section home-metrics">
      <div class="metrics-strip">
        <div class="metric">
          <div class="metric-num t-display"><Tally client:visible to={2} suffix="×" duration={900} /></div>
          <div class="metric-cap t-small">vs rsync · small files</div>
        </div>
        <div class="metric">
          <div class="metric-num t-display"><Tally client:visible to={16} duration={1000} /><span style="font-size: 0.5em; vertical-align: super; margin-left: 6px;">mib</span></div>
          <div class="metric-cap t-small">dedup · min block</div>
        </div>
        <div class="metric">
          <div class="metric-num t-display"><Tally client:visible to={4} duration={800} /></div>
          <div class="metric-cap t-small">platforms supported</div>
        </div>
        <div class="metric">
          <div class="metric-num t-display">blake3</div>
          <div class="metric-cap t-small">every chunk · hashed</div>
        </div>
      </div>
    </section>

    <section class="home-cta">
      <div class="cta-inner">
        <div class="t-small" style="color: var(--c-steel-3);">§ 04 · begin</div>
        <h2 class="t-display lower" style="color: var(--c-paper-pure);">
          <BlockReveal client:visible delay={200} color="var(--yellow)">one verb.</BlockReveal><br/>
          <BlockReveal client:visible delay={700} color="var(--red)">verified.</BlockReveal><br/>
          <BlockReveal client:visible delay={1200} color="var(--blue)">resumable.</BlockReveal>
        </h2>
        <div class="cta-buttons">
          <a class="btn-block" style="background: var(--c-paper-pure); color: var(--c-ink-0); border-color: var(--c-paper-pure);" href={bcmrProduct.href('/install')}>
            install bcmr ↳
          </a>
          <a class="btn-block" style="background: transparent; color: var(--c-paper-pure); border-color: var(--c-paper-pure);" href={bcmrProduct.href('/docs/getting-started')}>
            read docs
          </a>
        </div>
        <div class="cta-small t-mono-sm">
          mit licensed · no telemetry · open source since 2024
        </div>
      </div>
    </section>

    <Footer product={bcmrProduct} locale="en" languages={bcmrProduct.pageLanguages('en', '/', ['en', 'zh', 'zh-Hant'])} />
  </div>
</DefaultLayout>
