---
import DocsLayout from '@snaix/docs-theme/layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import { snaixConfig } from 'virtual:snaix-config';
import {
  DEFAULT_LOCALE,
  bareSlug,
  docsBaseFor,
  languagesFor,
  navFor,
  topNavFor,
} from '../../../lib/docs.ts';
import { product } from '../../../lib/product.ts';

const bcmrProduct = product('bcmr');

export async function getStaticPaths() {
  const sections = ['guide', 'cli'];
  const entries = await getCollection('docs', (e) => {
    const slug = e.slug.toLowerCase();
    const locale = e.data.locale ?? 'en';
    if (locale !== 'en') return false;
    if (/^([a-z-]+)\//.test(slug) && !slug.startsWith('cli/') && !slug.startsWith('ablation/')) {
      return false;
    }
    const sec = e.data.section ?? 'guide';
    return sections.includes(sec);
  });
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const DOCS_SECTIONS = ['guide', 'cli'];

const { entry } = Astro.props;
const all = await getCollection('docs');
const nav = await navFor(DEFAULT_LOCALE, DOCS_SECTIONS, all);
const languages = await languagesFor(entry, '/docs', all);
const { Content, headings } = await entry.render();
const toc = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({ slug: h.slug, text: h.text, depth: h.depth }));

const bare = bareSlug(entry.slug);
const sectionKey = entry.data.section ?? 'guide';
const sectionLabel = DEFAULT_LOCALE.ui?.sections?.[sectionKey] ?? sectionKey;
const docsLabel = DEFAULT_LOCALE.ui?.docsLabel ?? 'docs';
const breadcrumb = [docsLabel, sectionLabel, entry.data.title];

const currentTab = sectionKey === 'cli' ? 'commands' : 'docs';
---
<DocsLayout
  product={bcmrProduct}
  brand={snaixConfig.title}
  version={snaixConfig.version}
  current={bare}
  nav={nav}
  title={entry.data.title}
  description={entry.data.description}
  breadcrumb={breadcrumb}
  toc={toc}
  source={{
    path: `docs/${bare}.md`,
    url: `https://github.com/Bengerthelorf/bcmr/edit/main/docs/${bare}.md`,
  }}
  locale={DEFAULT_LOCALE.code}
  languages={languages}
  docsBase={docsBaseFor(DEFAULT_LOCALE)}
  tocLabel={DEFAULT_LOCALE.ui?.tocLabel ?? 'on this page'}
  math={true}
  mermaid={true}
  topNav={topNavFor(DEFAULT_LOCALE)}
  currentTab={currentTab}
>
  <Content />
</DocsLayout>
