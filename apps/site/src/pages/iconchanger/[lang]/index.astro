---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import IcMacWindow from '@snaix/docs-theme/components/IcMacWindow.astro';
import { BlockReveal, Scramble, Tally, Typewriter } from '@snaix/docs-theme';
import '@snaix/docs-theme/styles/iconchanger.css';
import { resolveLocale } from '../../../lib/docs.ts';
import { product } from '../../../lib/product.ts';

export async function getStaticPaths() {
  return ['zh', 'zh-Hant'].map((code) => ({ params: { lang: code } }));
}

const iconchanger = product('iconchanger');
const locale = resolveLocale(Astro.params.lang!);

const copy = {
  zh: {
    title: '一次一个图标',
    topLine: 'iconchanger / macos 原生',
    topMid: 'swift · appkit · 已签名',
    overview: '§ 01 · 概览',
    eyebrow: '// 你的 dock，你说了算。',
    headline: ['换掉', '每一个', '图标。'],
    ledePre: '随手替换任意 macOS 应用图标。浏览 ',
    ledeLink: 'macosicons.com',
    ledeMid: ' 上精选的数千个图标变体，从你自己的 ',
    ledeCodeIcns: '.icns',
    ledeMid2: ' 文件里挑，或者扔一张 png。dock 实时刷新。每个应用可一键还原。不改系统、完全沙盒化。',
    cta: '↳ 下载 macOS 版',
    ctaGhost: '了解更多',
    cmdMeta: '需要 macOS 13+',
    ribbon: [
      { t: 'macosicons.com', d: '直接浏览社区图标库。搜索、筛选、预览。' },
      { t: '实时 dock', d: '换之前就能在真实 dock 里看效果 —— 不是示意图。' },
      { t: '按应用还原', d: '每个更改都可撤销。任意应用一键恢复默认。' },
      { t: '沙盒化', d: '已签名、已公证、沙盒化。不改系统、不用 SIP 技巧。' },
    ],
    sec2: '§ 02 · 特性',
    sec2Title: ['它', '做什么。'],
    sec2Lede: 'iconchanger 是 macos 原生 GUI，不是脚本。它真读取你的应用文件夹，写 CFBundleIconFile 条目，原地刷新 dock。三列能力，每一项都可还原。',
    features: [
      { n: '01 · 浏览', h: '从几千个里挑。', p: '来自 macosicons.com 的实时 feed。按应用搜索，按风格筛选（扁平、aqua、单色、手绘、像素风）。提交前在真实 dock 里预览。' },
      { n: '02 · 本地', h: '扔你自己的。', p: '把 .icns、.png 或 .jpg 拖到任意应用上。iconchanger 自动生成所需尺寸（16、32、128、256、512、1024）。' },
      { n: '03 · 还原', h: '按应用撤销。', p: '每次更改都有记录。任意应用点还原默认，或一键全部还原。原图标从不删除 —— 和自定义图标并存。' },
    ],
    sec3: '§ 03 · 来源',
    sec3Title: ['任意', '输入', '格式。'],
    sec3Lede: '你不应该因为 iconchanger 是否支持而选择图标来源。扔任何合理格式进来，iconchanger 负责转换。',
    sources: [
      { k: '01', h: 'macosicons.com', d: '庞大的图标库。数千个社区图标，按应用和风格搜索。' },
      { k: '02', h: '.icns 文件',     d: 'apple 的原生格式。扔下文件，iconchanger 读取所有分辨率。' },
      { k: '03', h: 'png / jpg',      d: 'iconchanger 降采样为所需的六种尺寸，并生成 retina 配对。' },
      { k: '04', h: 'svg',            d: '矢量输入在首次使用时栅格化并缓存。每个尺寸都清晰。' },
      { k: '05', h: 'emoji',          d: '输入任意 emoji，立刻得到系统字体的圆角方形 dock 图标。' },
      { k: '06', h: '字母标记',       d: '选一个字母和背景色。适合没有明显图标的应用。' },
    ],
    metrics: [
      { cap: 'appkit · 原生' },
      { cap: '来源 · 格式' },
      { cap: '最低 · 签名 · 公证' },
      { cap: 'dock · 预览' },
    ],
    sec4: '§ 04 · 安装',
    sec4Headline: ['你的 dock。', '你说了算。'],
    downloadDmg: '下载 dmg ↳',
    brewCask: 'brew · cask',
    license: 'macos 13 ventura 或更新 · Apple Silicon & Intel · ~5 MB',
  },
  'zh-Hant': {
    title: '一次一個圖示',
    topLine: 'iconchanger / macos 原生',
    topMid: 'swift · appkit · 已簽署',
    overview: '§ 01 · 概覽',
    eyebrow: '// 你的 dock，你說了算。',
    headline: ['換掉', '每一個', '圖示。'],
    ledePre: '隨手替換任何 macOS 應用圖示。瀏覽 ',
    ledeLink: 'macosicons.com',
    ledeMid: ' 上精選的數千個圖示變體，從你自己的 ',
    ledeCodeIcns: '.icns',
    ledeMid2: ' 檔案裡挑，或者丟一張 png。dock 即時重新整理。每個應用可一鍵還原。不改系統、完全沙箱化。',
    cta: '↳ 下載 macOS 版',
    ctaGhost: '了解更多',
    cmdMeta: '需要 macOS 13+',
    ribbon: [
      { t: 'macosicons.com', d: '直接瀏覽社群圖示庫。搜尋、篩選、預覽。' },
      { t: '即時 dock', d: '提交前就能在真實 dock 裡看效果 —— 不是示意圖。' },
      { t: '按應用還原', d: '每次更改都可撤銷。任何應用一鍵恢復預設。' },
      { t: '沙箱化', d: '已簽署、已公證、沙箱化。不改系統、不用 SIP 技巧。' },
    ],
    sec2: '§ 02 · 特性',
    sec2Title: ['它', '做什麼。'],
    sec2Lede: 'iconchanger 是 macos 原生 GUI，不是腳本。它真讀取你的應用資料夾，寫 CFBundleIconFile 欄位，原地重載 dock。三欄能力，每一項都可還原。',
    features: [
      { n: '01 · 瀏覽', h: '從數千個裡挑。', p: '來自 macosicons.com 的即時 feed。按應用搜尋，按風格篩選（扁平、aqua、單色、手繪、像素）。提交前在真實 dock 裡預覽。' },
      { n: '02 · 本機', h: '丟你自己的。', p: '把 .icns、.png 或 .jpg 拖到任意應用上。iconchanger 自動產生所需尺寸（16、32、128、256、512、1024）。' },
      { n: '03 · 還原', h: '按應用撤銷。', p: '每次更改都有記錄。任意應用點還原預設，或一鍵全部還原。原圖示從不刪除 —— 和自訂圖示並存。' },
    ],
    sec3: '§ 03 · 來源',
    sec3Title: ['任何', '輸入', '格式。'],
    sec3Lede: '你不該因為 iconchanger 是否支援而選擇圖示來源。丟任何合理格式進來，iconchanger 負責轉換。',
    sources: [
      { k: '01', h: 'macosicons.com', d: '龐大的圖示庫。數千個社群圖示，按應用和風格搜尋。' },
      { k: '02', h: '.icns 檔案',     d: 'apple 的原生格式。丟下檔案，iconchanger 讀取所有解析度。' },
      { k: '03', h: 'png / jpg',      d: 'iconchanger 降取樣為所需的六種尺寸，並產生 retina 對。' },
      { k: '04', h: 'svg',            d: '向量輸入在首次使用時點陣化並快取。每個尺寸都銳利。' },
      { k: '05', h: 'emoji',          d: '輸入任何 emoji，立刻得到系統字體的圓角方形 dock 圖示。' },
      { k: '06', h: '字母標記',       d: '選一個字母和背景色。適合沒有明顯圖示的應用。' },
    ],
    metrics: [
      { cap: 'appkit · 原生' },
      { cap: '來源 · 格式' },
      { cap: '最低 · 簽署 · 公證' },
      { cap: 'dock · 預覽' },
    ],
    sec4: '§ 04 · 安裝',
    sec4Headline: ['你的 dock。', '你說了算。'],
    downloadDmg: '下載 dmg ↳',
    brewCask: 'brew · cask',
    license: 'macos 13 ventura 或更新 · Apple Silicon & Intel · ~5 MB',
  },
} as const;

const t = copy[locale.code as 'zh' | 'zh-Hant'];

const nav = [
  { id: 'home',      label: 'overview',  href: iconchanger.href(`/${locale.code}/`) },
  { id: 'feat',      label: 'features',  href: '#features' },
  { id: 'sources',   label: 'sources',   href: '#sources' },
  { id: 'docs',      label: 'docs',      href: iconchanger.href(`/${locale.code}/docs/getting-started`) },
  { id: 'commands',  label: 'cli',       href: iconchanger.href(`/${locale.code}/commands`) },
  { id: 'install',   label: 'install',   href: iconchanger.href(`/${locale.code}/install`) },
  { id: 'changelog', label: 'changelog', href: iconchanger.href(`/${locale.code}/changelog`) },
];
---
<DefaultLayout title={`${iconchanger.title} — ${t.title}`} lang={locale.lang ?? locale.code}>
  <div class="page ic-body">
    <TopBar
      brand={iconchanger.title}
      version={iconchanger.version}
      current="home"
      githubHref={iconchanger.githubUrl}
      nav={nav}
    >
      <Fragment slot="logo">
        <rect x="2"  y="2"  width="17" height="17" rx="4" fill="var(--red)" />
        <rect x="21" y="2"  width="17" height="17" rx="4" fill="var(--yellow)" />
        <rect x="2"  y="21" width="17" height="17" rx="4" fill="var(--blue)" />
        <rect x="21" y="21" width="17" height="17" rx="4" fill="var(--ink)" />
      </Fragment>
    </TopBar>

    <section class="ic-hero">
      <div class="ic-hero-top rule-b">
        <span class="t-mono-sm">{t.topLine}</span>
        <span class="t-mono-sm">{t.topMid}</span>
        <span class="t-mono-sm">{iconchanger.version} · {iconchanger.releaseDate}</span>
      </div>

      <div class="ic-hero-grid">
        <div class="ic-hero-left">
          <div class="ic-hero-eyebrow">
            <span class="t-small">{t.overview}</span>
            <span class="t-mono-sm" style="color: var(--steel-5);">
              <Typewriter client:visible text={t.eyebrow} speed={24} delay={300} />
            </span>
          </div>
          <h1 class="ic-hero-title lower">
            <span class="hl-line"><BlockReveal client:visible delay={300} duration={520} color="var(--red)">{t.headline[0]}</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:visible delay={700} duration={520} color="var(--yellow)">{t.headline[1]}</BlockReveal></span>
            <span class="hl-line em-red"><BlockReveal client:visible delay={1100} duration={520} color="var(--blue)">{t.headline[2]}</BlockReveal></span>
          </h1>
          <p class="ic-lede">
            {t.ledePre}<a class="link-u" href="https://macosicons.com">{t.ledeLink}</a>{t.ledeMid}<code>{t.ledeCodeIcns}</code>{t.ledeMid2}
          </p>
          <div class="ic-cta">
            <a class="btn-block" href="#install">{t.cta}</a>
            <a class="btn-block is-ghost" href="#features">{t.ctaGhost}</a>
            <span class="ic-cta-meta">
              ⌘ <span>{t.cmdMeta}</span>
            </span>
          </div>
        </div>

        <aside class="ic-hero-right">
          <IcMacWindow />
        </aside>
      </div>

      <div class="ic-ribbon">
        {t.ribbon.map((r, i) => (
          <div class="item">
            <span class="t-small">{String(i + 1).padStart(2, '0')}</span>
            <div class="lbl"><Scramble client:visible text={r.t} delay={200 + i * 120} /></div>
            <div class="sub">{r.d}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="ic-section" id="features">
      <div class="ic-section-head">
        <div class="lhs">
          <div class="t-small">{t.sec2}</div>
          <h2 class="t-h1 lower">{t.sec2Title[0]}<br />{t.sec2Title[1]}</h2>
        </div>
        <div class="rhs">
          <p class="t-body">{t.sec2Lede}</p>
        </div>
      </div>
      <div class="ic-features">
        {t.features.map((f) => (
          <div class="col">
            <div class="n">{f.n}</div>
            <h3 class="lower">{f.h}</h3>
            <p>{f.p}</p>
            <div class="mark" />
          </div>
        ))}
      </div>
    </section>

    <section class="ic-section" id="sources">
      <div class="ic-section-head">
        <div class="lhs">
          <div class="t-small">{t.sec3}</div>
          <h2 class="t-h1 lower">{t.sec3Title[0]}<br />{t.sec3Title[1]}<br />{t.sec3Title[2]}</h2>
        </div>
        <div class="rhs">
          <p class="t-body">{t.sec3Lede}</p>
        </div>
      </div>
      <div class="ic-sources">
        {t.sources.map((s) => (
          <div class="ic-src">
            <div class="k">{s.k}</div>
            <div class="h lower">{s.h}</div>
            <div class="d">{s.d}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="ic-section">
      <div class="ic-metrics">
        <div class="ic-metric">
          <div class="n">swift</div>
          <div class="c">{t.metrics[0].cap}</div>
        </div>
        <div class="ic-metric">
          <div class="n"><Tally client:visible to={6} duration={800} /></div>
          <div class="c">{t.metrics[1].cap}</div>
        </div>
        <div class="ic-metric">
          <div class="n">mac 13+</div>
          <div class="c">{t.metrics[2].cap}</div>
        </div>
        <div class="ic-metric">
          <div class="n">live</div>
          <div class="c">{t.metrics[3].cap}</div>
        </div>
      </div>
    </section>

    <section class="ic-cta-full" id="install">
      <div class="ic-cta-inner">
        <div class="t-small" style="color: rgba(255,255,255,0.7);">{t.sec4}</div>
        <h2 class="lower">
          <BlockReveal client:visible delay={200} color="var(--yellow)">{t.sec4Headline[0]}</BlockReveal><br />
          <BlockReveal client:visible delay={700} color="var(--ink)">{t.sec4Headline[1]}</BlockReveal>
        </h2>
        <div class="buttons">
          <a class="btn-block" style="background: var(--c-paper-pure); color: var(--c-ink-0); border-color: var(--c-paper-pure);" href={iconchanger.href(`/${locale.code}/install`)}>
            {t.downloadDmg}
          </a>
          <a class="btn-block" style="background: transparent; color: var(--c-paper-pure); border-color: var(--c-paper-pure);" href={`${iconchanger.githubUrl}/releases`}>
            {t.brewCask}
          </a>
        </div>
        <div class="t-mono-sm" style="margin-top: 28px; color: rgba(255,255,255,0.7);">
          {t.license}
        </div>
      </div>
    </section>

    <Footer product={iconchanger} locale={locale.code} languages={iconchanger.pageLanguages(locale.code, '/', ['en', 'zh', 'zh-Hant'])} />
  </div>
</DefaultLayout>
