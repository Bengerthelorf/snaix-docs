---
import DocsLayout from '@snaix/docs-theme/layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import {
  DEFAULT_LOCALE,
  LOCALES,
  bareSlug,
  docsBaseFor,
  navFor,
  resolveLocale,
} from '../../../../lib/docs.ts';
import { product } from '../../../../lib/product.ts';

const iconchanger = product('iconchanger');

export async function getStaticPaths() {
  const all = await getCollection('iconchanger');
  const paths = [];
  for (const locale of LOCALES) {
    if (locale.code === DEFAULT_LOCALE.code) continue;
    const prefix = `${locale.code.toLowerCase()}/`;
    const entries = all.filter(
      (e) =>
        e.slug.toLowerCase().startsWith(prefix) &&
        ['guide', 'cli'].includes(e.data.section ?? 'guide'),
    );
    for (const entry of entries) {
      paths.push({
        params: { lang: locale.code, slug: bareSlug(entry.slug) },
        props: { entry, localeCode: locale.code },
      });
    }
  }
  return paths;
}

const { entry, localeCode } = Astro.props;
const locale = resolveLocale(localeCode);
const all = await getCollection('iconchanger');
const nav = await navFor(locale, all, ['guide', 'cli'], { docsRoot: '/iconchanger/docs' });
const languages = iconchanger.docsLanguages(entry, all, locale);
const { Content, headings } = await entry.render();
const toc = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({ slug: h.slug, text: h.text, depth: h.depth }));

const bare = bareSlug(entry.slug);
const sectionLabel = locale.ui?.sections?.['guide'] ?? 'guide';
const docsLabel = locale.ui?.docsLabel ?? 'docs';
const breadcrumb = [docsLabel, sectionLabel, entry.data.title];
---
<DocsLayout
  product={iconchanger}
  brand={iconchanger.title}
  version={iconchanger.version}
  current={bare}
  nav={nav}
  title={entry.data.title}
  description={entry.data.description}
  breadcrumb={breadcrumb}
  toc={toc}
  source={{
    path: `docs/${locale.code}/${bare}.md`,
    url: `https://github.com/Bengerthelorf/macIconChanger/edit/main/docs/${locale.code}/${bare}.md`,
  }}
  locale={locale.lang ?? locale.code}
  languages={languages}
  docsBase={docsBaseFor(locale, '/iconchanger/docs')}
  tocLabel={locale.ui?.tocLabel ?? 'on this page'}
  topNav={iconchanger.nav()}
  currentTab="docs"
>
  <Content />
</DocsLayout>
