---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import { BlockReveal, Scramble, Typewriter } from '@snaix/docs-theme';
import { product } from '../../lib/product.ts';

const iconchanger = product('iconchanger');
const languages = iconchanger.pageLanguages('en', '/');

const highlights = [
  { n: '01', t: 'any macos icon',        d: 'apps, folders, system volumes. drag to swap, drag to reset.' },
  { n: '02', t: 'macosicons.com search', d: '~70k community icons searchable from inside the app. nothing to download.' },
  { n: '03', t: 'dock preview',          d: 'see the dock with your custom icons before committing — live, not rendered.' },
  { n: '04', t: 'background service',    d: 'macos updates overwrite icons. the launchd agent restores them on a schedule.' },
  { n: '05', t: 'full cli',              d: 'ic set / ic reset / ic export — scriptable for dotfiles, ansible, chezmoi.' },
  { n: '06', t: 'aliases · favorites',   d: 'save icon-app pairings. re-apply with one click after a clean install.' },
  { n: '07', t: '30 languages',          d: 'localized end-to-end: ui · help · error messages. not just strings.' },
  { n: '08', t: 'native swift',          d: 'swiftui + appkit, not electron. 20 mb binary, no background daemon by default.' },
];
---
<DefaultLayout title={`${iconchanger.title} — ${iconchanger.tagline}`}>
  <div class="page home">
    <TopBar
      brand={iconchanger.title}
      version={iconchanger.version}
      current="home"
      logoVariant="product"
      showStatus={false}
      githubHref={iconchanger.githubUrl}
      nav={iconchanger.nav()}
    />

    <section class="hero">
      <div class="hero-top rule-b">
        <span class="t-mono-sm">iconchanger · {iconchanger.tagline}</span>
        <span class="t-mono-sm">gui + cli · macos native</span>
        <span class="t-mono-sm">{iconchanger.version} · {iconchanger.releaseDate}</span>
      </div>

      <div class="hero-grid grid12">
        <div class="hero-headline">
          <div class="hero-eyebrow">
            <span class="t-small">§ 01 · overview</span>
            <span class="t-mono-sm" style="color: var(--steel-5);">
              <Typewriter client:load text="// customize any macos icon." speed={24} delay={300} />
            </span>
          </div>
          <h1 class="t-display lower">
            <span class="hl-line"><BlockReveal client:load delay={400} duration={520}>drag.</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:load delay={760} duration={520} color="var(--red)">drop.</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:load delay={1120} duration={520} color="var(--blue)">done.</BlockReveal></span>
          </h1>

          <p class="hero-lede">
            customize any macos app or folder icon. beautiful gui with live
            dock preview, full cli for scripting, ~70k icons searchable via
            macosicons.com, and a background service that restores them after
            system updates.
          </p>

          <div class="hero-cta">
            <a class="btn-block" href={iconchanger.href('/install')}>↳ install {iconchanger.version}</a>
            <a class="btn-block is-ghost" href={iconchanger.href('/docs/getting-started')}>read the docs</a>
            <span class="hero-cta-meta t-mono-sm">
              ⌘ <span>brew install Bengerthelorf/tap/iconchanger</span>
            </span>
          </div>
        </div>

        <aside class="hero-device hero-device--image">
          <div class="device-head">
            <div class="t-small">app.live</div>
            <div class="chip is-blue"><span class="dot"/>swiftui</div>
          </div>
          <img
            src={iconchanger.href('/images/hero-screenshot-light.png')}
            alt="iconchanger main window with icon search and dock preview"
            loading="eager"
            decoding="async"
          />
          <div class="device-footline">
            <span class="t-mono-sm">swiftui + appkit · macos 13+</span>
            <span class="t-mono-sm" style="color: var(--blue);">● native</span>
          </div>
        </aside>
      </div>

      <div class="hero-ribbon rule-t">
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">01</span>
            <span class="ribbon-label"><Scramble client:load text="any macos icon" delay={200} /></span>
          </div>
          <div class="ribbon-sub">apps, folders, volumes. drag to swap, drag to reset, no terminal required.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">02</span>
            <span class="ribbon-label"><Scramble client:load text="70k icon library" delay={350} /></span>
          </div>
          <div class="ribbon-sub">search macosicons.com inline. preview, apply, favorite — no downloads folder.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">03</span>
            <span class="ribbon-label"><Scramble client:load text="survives updates" delay={500} /></span>
          </div>
          <div class="ribbon-sub">launchd agent re-applies your aliases after macos overwrites them. off by default.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">04</span>
            <span class="ribbon-label"><Scramble client:load text="scriptable cli" delay={650} /></span>
          </div>
          <div class="ribbon-sub">ic set / ic export / ic reset. works with dotfiles, chezmoi, ansible — anywhere.</div>
        </div>
      </div>
    </section>

    <section class="home-section home-principles">
      <div class="section-head">
        <div class="section-head-left">
          <div class="t-small">§ 02 · features</div>
          <h2 class="t-h1 lower">eight things<br/>it does well.</h2>
        </div>
        <div class="section-head-right">
          <p class="t-body">
            iconchanger does one thing: change your icons, and keep them changed.
            the features below exist because icon customization needs them, not
            because they were fun to build.
          </p>
        </div>
      </div>

      <div class="principles-grid">
        {highlights.map((it) => (
          <div class="principle">
            <div class="principle-n t-mono">{it.n}</div>
            <div class="principle-title t-h3 lower">{it.t}</div>
            <div class="principle-d">{it.d}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="home-cta">
      <div class="cta-inner">
        <div class="t-small" style="color: var(--steel-3);">§ 03 · begin</div>
        <h2 class="t-display lower" style="color: var(--paper-pure);">
          <BlockReveal client:load delay={200} color="var(--yellow)">drag.</BlockReveal><br/>
          <BlockReveal client:load delay={700} color="var(--red)">drop.</BlockReveal><br/>
          <BlockReveal client:load delay={1200} color="var(--blue)">done.</BlockReveal>
        </h2>
        <div class="cta-buttons">
          <a class="btn-block" style="background: var(--paper-pure); color: var(--ink); border-color: var(--paper-pure);" href={iconchanger.href('/docs/getting-started')}>
            get started ↳
          </a>
          <a class="btn-block" style="background: transparent; color: var(--paper-pure); border-color: var(--paper-pure);" href={iconchanger.href('/docs/cli/commands')}>
            cli reference
          </a>
        </div>
        <div class="cta-small t-mono-sm">
          mit licensed · no telemetry · open source
        </div>
      </div>
    </section>

    <Footer product={iconchanger} locale="en" languages={languages} />
  </div>
</DefaultLayout>

<style>
  .hero-device--image {
    padding: 0;
    background: var(--paper);
  }
  .hero-device--image img {
    display: block;
    width: 100%;
    height: auto;
    border-top: 1px solid var(--steel-3);
    border-bottom: 1px solid var(--steel-3);
  }
</style>
