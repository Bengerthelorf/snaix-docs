---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import IcMacWindow from '@snaix/docs-theme/components/IcMacWindow.astro';
import { BlockReveal, Scramble, Tally, Typewriter } from '@snaix/docs-theme';
import '@snaix/docs-theme/styles/iconchanger.css';
import { product } from '../../lib/product.ts';

const iconchanger = product('iconchanger');

const nav = [
  { id: 'home',    label: 'overview', href: iconchanger.href('/') },
  { id: 'feat',    label: 'features', href: '#features' },
  { id: 'sources', label: 'sources',  href: '#sources' },
  { id: 'docs',    label: 'docs',     href: iconchanger.href('/docs/getting-started') },
  { id: 'install', label: 'install',  href: '#install' },
];

const sources = [
  { k: '01', h: 'macosicons.com', d: 'the big library. thousands of community icons, searchable by app and by style.' },
  { k: '02', h: '.icns files',    d: "apple's native format. drop the bundle, iconchanger reads all resolutions." },
  { k: '03', h: 'png / jpg',      d: 'iconchanger downsamples to the six required sizes and generates retina pairs.' },
  { k: '04', h: 'svg',            d: 'vector input is rasterised on first use and cached. sharp at every size.' },
  { k: '05', h: 'emoji',          d: 'type any emoji, get a rounded-square dock icon in the system font. instant.' },
  { k: '06', h: 'letter mark',    d: 'pick a letter and a background colour. good for apps without a clear icon.' },
];
---
<DefaultLayout title={`${iconchanger.title} — ${iconchanger.tagline}`}>
  <div class="page ic-body">
    <TopBar
      brand={iconchanger.title}
      version={iconchanger.version}
      current="home"
      githubHref={iconchanger.githubUrl}
      nav={nav}
      showStatus={false}
    >
      <Fragment slot="logo">
        <rect x="2"  y="2"  width="17" height="17" rx="4" fill="var(--red)" />
        <rect x="21" y="2"  width="17" height="17" rx="4" fill="var(--yellow)" />
        <rect x="2"  y="21" width="17" height="17" rx="4" fill="var(--blue)" />
        <rect x="21" y="21" width="17" height="17" rx="4" fill="var(--ink)" />
      </Fragment>
    </TopBar>

    <section class="ic-hero">
      <div class="ic-hero-top rule-b">
        <span class="t-mono-sm">iconchanger / macos native</span>
        <span class="t-mono-sm">swift · appkit · signed</span>
        <span class="t-mono-sm">{iconchanger.version} · {iconchanger.releaseDate}</span>
      </div>

      <div class="ic-hero-grid">
        <div class="ic-hero-left">
          <div class="ic-hero-eyebrow">
            <span class="t-small">§ 01 · overview</span>
            <span class="t-mono-sm" style="color: var(--steel-5);">
              <Typewriter client:visible text="// your dock, your rules." speed={24} delay={300} />
            </span>
          </div>
          <h1 class="ic-hero-title lower">
            <span class="hl-line"><BlockReveal client:visible delay={300} duration={520} color="var(--red)">change</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:visible delay={700} duration={520} color="var(--yellow)">every</BlockReveal></span>
            <span class="hl-line em-red"><BlockReveal client:visible delay={1100} duration={520} color="var(--blue)">icon.</BlockReveal></span>
          </h1>
          <p class="ic-lede">
            swap any app icon on macos. browse thousands of curated variants
            from <a class="link-u" href="https://macosicons.com">macosicons.com</a>,
            pick from your own <code>.icns</code> files, or drop a png. dock
            refreshes live. revertable per-app with one click. no restarts,
            no system modifications, fully sandboxed.
          </p>
          <div class="ic-cta">
            <a class="btn-block" href="#install">↳ download for macos</a>
            <a class="btn-block is-ghost" href="#features">read more</a>
            <span class="ic-cta-meta">
              ⌘ <span>requires macos 13+</span>
            </span>
          </div>
        </div>

        <aside class="ic-hero-right">
          <IcMacWindow />
        </aside>
      </div>

      <div class="ic-ribbon">
        <div class="item">
          <span class="t-small">01</span>
          <div class="lbl"><Scramble client:visible text="macosicons.com" delay={200} /></div>
          <div class="sub">direct browse into the community icon library. search, filter, preview.</div>
        </div>
        <div class="item">
          <span class="t-small">02</span>
          <div class="lbl"><Scramble client:visible text="live dock" delay={320} /></div>
          <div class="sub">see your new icon in a live dock preview before you commit. no surprises.</div>
        </div>
        <div class="item">
          <span class="t-small">03</span>
          <div class="lbl"><Scramble client:visible text="per-app revert" delay={440} /></div>
          <div class="sub">every change is reversible. restore default on any app with one click.</div>
        </div>
        <div class="item">
          <span class="t-small">04</span>
          <div class="lbl"><Scramble client:visible text="sandboxed" delay={560} /></div>
          <div class="sub">signed, notarised, sandboxed. no system mods, no reboots, no SIP tricks.</div>
        </div>
      </div>
    </section>

    <section class="ic-section" id="features">
      <div class="ic-section-head">
        <div class="lhs">
          <div class="t-small">§ 02 · features</div>
          <h2 class="t-h1 lower">what<br />it does.</h2>
        </div>
        <div class="rhs">
          <p class="t-body">
            iconchanger is a macos-native gui, not a script. it reads your
            actual applications folder, writes <code>CFBundleIconFile</code>
            entries, and reloads the dock in-place. three columns of
            capability, all reversible.
          </p>
        </div>
      </div>
      <div class="ic-features">
        <div class="col">
          <div class="n">01 · browse</div>
          <h3 class="lower">pick from thousands.</h3>
          <p>
            live feed from macosicons.com. search by app, filter by style
            (flat, aqua, monochrome, hand-drawn, pixel). preview on a live
            dock before you commit.
          </p>
          <div class="mark" />
        </div>
        <div class="col">
          <div class="n">02 · local</div>
          <h3 class="lower">drop your own.</h3>
          <p>
            drag a <code>.icns</code>, <code>.png</code>, or <code>.jpg</code>
            onto any app. iconchanger generates the correct sizes (16, 32,
            128, 256, 512, 1024) automatically.
          </p>
          <div class="mark" />
        </div>
        <div class="col">
          <div class="n">03 · revert</div>
          <h3 class="lower">undo per app.</h3>
          <p>
            every change is tracked. click restore default on any app, or
            restore all at once. the original icons are never deleted —
            they sit beside the custom one.
          </p>
          <div class="mark" />
        </div>
      </div>
    </section>

    <section class="ic-section" id="sources">
      <div class="ic-section-head">
        <div class="lhs">
          <div class="t-small">§ 03 · sources</div>
          <h2 class="t-h1 lower">every<br />kind<br />of input.</h2>
        </div>
        <div class="rhs">
          <p class="t-body">
            you should not have to choose your icon source by whether
            iconchanger supports it. drop anything reasonable, iconchanger
            does the conversion.
          </p>
        </div>
      </div>
      <div class="ic-sources">
        {sources.map((s) => (
          <div class="ic-src">
            <div class="k">{s.k}</div>
            <div class="h lower">{s.h}</div>
            <div class="d">{s.d}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="ic-section">
      <div class="ic-metrics">
        <div class="ic-metric">
          <div class="n">swift</div>
          <div class="c">appkit · native</div>
        </div>
        <div class="ic-metric">
          <div class="n"><Tally client:visible to={6} duration={800} /></div>
          <div class="c">input formats</div>
        </div>
        <div class="ic-metric">
          <div class="n">mac 13+</div>
          <div class="c">min · signed · notarised</div>
        </div>
        <div class="ic-metric">
          <div class="n"><Tally client:visible to={0} duration={600} /></div>
          <div class="c">reboots required</div>
        </div>
      </div>
    </section>

    <section class="ic-cta-full" id="install">
      <div class="ic-cta-inner">
        <div class="t-small" style="color: rgba(255,255,255,0.7);">§ 04 · install</div>
        <h2 class="lower">
          <BlockReveal client:visible delay={200} color="var(--yellow)">your dock.</BlockReveal><br />
          <BlockReveal client:visible delay={700} color="var(--ink)">your rules.</BlockReveal>
        </h2>
        <div class="buttons">
          <a class="btn-block" style="background: var(--c-paper-pure); color: var(--c-ink-0); border-color: var(--c-paper-pure);" href={iconchanger.href('/install')}>
            download dmg ↳
          </a>
          <a class="btn-block" style="background: transparent; color: var(--c-paper-pure); border-color: var(--c-paper-pure);" href={`${iconchanger.githubUrl}/releases`}>
            brew · cask
          </a>
        </div>
        <div class="t-mono-sm" style="margin-top: 28px; color: rgba(255,255,255,0.7);">
          macos 13 ventura or later · apple silicon & intel · ~12 MB
        </div>
      </div>
    </section>

    <Footer product={iconchanger} locale="en" languages={iconchanger.pageLanguages('en', '/')} />
  </div>
</DefaultLayout>
