---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import { BlockReveal, InstallTabs } from '@snaix/docs-theme';
import { product } from '../../lib/product.ts';

const iconchanger = product('iconchanger');
---
<DefaultLayout title={`${iconchanger.title} · install`}>
  <div class="page install">
    <TopBar
      brand={iconchanger.title}
      version={iconchanger.version}
      current="install"
      githubHref={iconchanger.githubUrl}
      nav={iconchanger.nav()}
    />

    <section class="install-hero">
      <div class="t-small" style="color: var(--red);">§ install</div>
      <h1 class="install-title lower">
        <BlockReveal client:load>two</BlockReveal> <BlockReveal client:load color="var(--red)" delay={300}>ways</BlockReveal><br/>
        <BlockReveal client:load color="var(--blue)" delay={600}>in.</BlockReveal>
      </h1>
      <p class="t-body" style="margin-top: 24px; max-width: 560px;">
        iconchanger is a native macOS app. homebrew or DMG — pick one, under a
        minute either way. runs 100% on-device, no account needed.
      </p>
    </section>

    <InstallTabs client:load options={iconchanger.install} />

    <section class="install-after">
      <div class="install-after-grid">
        <div>
          <div class="t-small" style="color: var(--red);">§ next</div>
          <h2 class="t-h2 lower" style="margin-top: 8px;">launch &amp;<br/>swap an icon.</h2>
        </div>
        <div>
          <ol class="install-after-steps">
            <li><span class="step-key">open</span><span class="step-desc">iconchanger from Spotlight or your Applications folder.</span></li>
            <li><span class="step-key">drag</span><span class="step-desc">any app from <code>/Applications</code> into the window.</span></li>
            <li><span class="step-key">pick</span><span class="step-desc">an icon — search macosicons.com, or drop a .png / .icns / .svg.</span></li>
            <li><span class="step-key">apply</span><span class="step-desc">the Dock refreshes live. revert per-app from the same row.</span></li>
          </ol>
          <p style="margin-top: 18px;">
            prefer the cli? see the <a class="link-u" href="/iconchanger/commands">command reference</a>.
          </p>
        </div>
      </div>
    </section>

    <Footer product={iconchanger} locale="en" />
  </div>
</DefaultLayout>

