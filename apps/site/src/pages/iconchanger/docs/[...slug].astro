---
import DocsLayout from '@snaix/docs-theme/layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import {
  DEFAULT_LOCALE,
  bareSlug,
  docsBaseFor,
  navFor,
} from '../../../lib/docs.ts';
import { product } from '../../../lib/product.ts';

const iconchanger = product('iconchanger');

export async function getStaticPaths() {
  const entries = await getCollection('iconchanger', (e) => {
    const slug = e.slug.toLowerCase();
    const locale = e.data.locale ?? 'en';
    if (locale !== 'en') return false;
    if (slug.startsWith('zh/') || slug.startsWith('zh-hant/')) return false;
    return ['guide', 'cli'].includes(e.data.section ?? 'guide');
  });
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const all = await getCollection('iconchanger');
const nav = await navFor(DEFAULT_LOCALE, all, ['guide', 'cli'], { docsRoot: '/iconchanger/docs' });
const languages = iconchanger.docsLanguages(entry, all, DEFAULT_LOCALE);
const { Content, headings } = await entry.render();
const toc = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({ slug: h.slug, text: h.text, depth: h.depth }));

const bare = bareSlug(entry.slug);
const sectionLabel = DEFAULT_LOCALE.ui?.sections?.['guide'] ?? 'guide';
const docsLabel = DEFAULT_LOCALE.ui?.docsLabel ?? 'docs';
const breadcrumb = [docsLabel, sectionLabel, entry.data.title];
---
<DocsLayout
  product={iconchanger}
  brand={iconchanger.title}
  version={iconchanger.version}
  current={bare}
  nav={nav}
  title={entry.data.title}
  description={entry.data.description}
  breadcrumb={breadcrumb}
  toc={toc}
  source={{
    path: `docs/${bare}.md`,
    url: `https://github.com/Bengerthelorf/macIconChanger/edit/main/docs/${bare}.md`,
  }}
  locale={DEFAULT_LOCALE.code}
  languages={languages}
  docsBase={docsBaseFor(DEFAULT_LOCALE, '/iconchanger/docs')}
  tocLabel={DEFAULT_LOCALE.ui?.tocLabel ?? 'on this page'}
  topNav={iconchanger.nav()}
  currentTab="docs"
>
  <Content />
</DocsLayout>
