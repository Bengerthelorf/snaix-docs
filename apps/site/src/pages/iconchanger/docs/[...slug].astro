---
import DocsLayout from '@snaix/docs-theme/layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import {
  DEFAULT_LOCALE,
  PRODUCT_DOCS_SECTIONS,
  bareSlug,
  docsBaseFor,
  isDefaultLocaleEntry,
  navFor,
} from '../../../lib/docs.ts';
import { product } from '../../../lib/product.ts';
import { mdxComponents } from '@snaix/docs-theme/mdx-components';

const iconchanger = product('iconchanger');

export async function getStaticPaths() {
  const entries = await getCollection('iconchanger', (e) =>
    isDefaultLocaleEntry(e) &&
    PRODUCT_DOCS_SECTIONS.includes(e.data.section ?? 'guide'),
  );
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const all = await getCollection('iconchanger');
const nav = await navFor(DEFAULT_LOCALE, all, PRODUCT_DOCS_SECTIONS, '/iconchanger/docs');
const { Content, headings } = await entry.render();
const toc = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({ slug: h.slug, text: h.text, depth: h.depth }));

const bare = bareSlug(entry.slug);
const sectionKey = entry.data.section ?? 'guide';
const sectionLabel = DEFAULT_LOCALE.ui?.sections?.[sectionKey] ?? sectionKey;
const docsLabel = DEFAULT_LOCALE.ui?.docsLabel ?? 'docs';
---
<DocsLayout
  product={iconchanger}
  brand={iconchanger.title}
  version={iconchanger.version}
  current={bare}
  nav={nav}
  title={entry.data.title}
  description={entry.data.description}
  breadcrumb={[docsLabel, sectionLabel, entry.data.title]}
  toc={toc}
  source={{
    path: `docs/${bare}.md`,
    url: `https://github.com/Bengerthelorf/macIconChanger/edit/main/docs/${bare}.md`,
  }}
  locale={DEFAULT_LOCALE.code}
  languages={iconchanger.docsLanguages(entry, all, DEFAULT_LOCALE)}
  docsBase={docsBaseFor(DEFAULT_LOCALE, '/iconchanger/docs')}
  tocLabel={DEFAULT_LOCALE.ui?.tocLabel ?? 'on this page'}
  topNav={iconchanger.nav()}
  currentTab={sectionKey === 'cli' ? 'commands' : 'docs'}
>
  <Content components={mdxComponents} />
</DocsLayout>
