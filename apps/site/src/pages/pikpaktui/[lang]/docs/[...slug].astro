---
import DocsLayout from '@snaix/docs-theme/layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import {
  DEFAULT_LOCALE,
  LOCALES,
  PRODUCT_DOCS_SECTIONS,
  bareSlug,
  docsBaseFor,
  navFor,
  pagerLabelsFor,
  resolveLocale,
  slugPrefix,
} from '../../../../lib/docs.ts';
import { product } from '../../../../lib/product.ts';
import { mdxComponents } from '@snaix/docs-theme/mdx-components';

const pikpaktui = product('pikpaktui');

export async function getStaticPaths() {
  const all = await getCollection('pikpaktui');
  const paths = [];
  for (const locale of LOCALES) {
    if (locale.code === DEFAULT_LOCALE.code) continue;
    const prefix = slugPrefix(locale, LOCALES);
    const entries = all.filter(
      (e) =>
        e.slug.toLowerCase().startsWith(prefix) &&
        PRODUCT_DOCS_SECTIONS.includes(e.data.section ?? 'guide'),
    );
    for (const entry of entries) {
      paths.push({
        params: { lang: locale.code, slug: bareSlug(entry.slug) },
        props: { entry, localeCode: locale.code },
      });
    }
  }
  return paths;
}

const { entry, localeCode } = Astro.props;
const locale = resolveLocale(localeCode);
const all = await getCollection('pikpaktui');
const nav = await navFor(locale, all, PRODUCT_DOCS_SECTIONS, '/pikpaktui/docs');
const { Content, headings } = await entry.render();
const toc = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({ slug: h.slug, text: h.text, depth: h.depth }));

const bare = bareSlug(entry.slug);
const sectionKey = entry.data.section ?? 'guide';
const sectionLabel = locale.ui?.sections?.[sectionKey] ?? sectionKey;
const docsLabel = locale.ui?.docsLabel ?? 'docs';
const pagerLabels = pagerLabelsFor(locale);
---
<DocsLayout
  product={pikpaktui}
  brand={pikpaktui.title}
  version={pikpaktui.version}
  current={bare}
  nav={nav}
  title={entry.data.title}
  description={entry.data.description}
  breadcrumb={[docsLabel, sectionLabel, entry.data.title]}
  toc={toc}
  source={{
    path: `docs/${locale.code}/${bare}.md`,
    url: `https://github.com/Bengerthelorf/pikpaktui/edit/main/docs/${locale.code}/${bare}.md`,
  }}
  locale={locale.lang ?? locale.code}
  languages={pikpaktui.docsLanguages(entry, all, locale)}
  docsBase={docsBaseFor(locale, '/pikpaktui/docs')}
  tocLabel={locale.ui?.tocLabel ?? 'on this page'}
  topNav={pikpaktui.nav()}
  currentTab="docs"
  pagerLabels={pagerLabels}
>
  <Content components={mdxComponents} />
</DocsLayout>
