---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import { BlockReveal, Scramble, Typewriter } from '@snaix/docs-theme';
import { LOCALES, DEFAULT_LOCALE, resolveLocale } from '../../../lib/docs.ts';
import { product } from '../../../lib/product.ts';

export async function getStaticPaths() {
  return ['zh', 'zh-Hant'].map((code) => ({ params: { lang: code } }));
}

const pikpaktui = product('pikpaktui');
const locale = resolveLocale(Astro.params.lang!);

const copy = {
  zh: {
    tagline: 'pikpak 在你的终端里',
    eyebrow: 'pikpak · 在你的终端里。',
    overview: '§ 01 · 概览',
    headline: ['浏览.', '播放.', '脚本化.'],
    lede: '一个用于 PikPak 云存储的 TUI + CLI 客户端。三栏米勒布局、缩略图预览、28 条子命令、视频流播到 iina/mpv/vlc、Shell 补全、离线下载 —— 全部用纯 Rust 写成。',
    install: '↳ 安装',
    docs: '阅读文档',
    topLine: 'pikpaktui · pikpak 在你的终端里',
    topMid: 'tui + cli · 纯 rust',
    footerTail: '三栏 · ratatui',
    interactiveChip: '互动',
    features: [
      { n: '01', t: '三栏 tui',         d: 'yazi 风格的米勒布局，支持实时缩略图、语法高亮和键盘导航。' },
      { n: '02', t: '28 条子命令',      d: 'ls · mv · cp · rm · download · upload · share · update。彩色输出、--json、--dry-run。' },
      { n: '03', t: '视频流播到播放器', d: '按 Enter 选择画质，直接流播到 iina / mpv / vlc —— 文件不落盘。' },
      { n: '04', t: '离线下载',         d: '向 PikPak 服务器提交磁力链接或 URL，从 TUI 里查看任务状态。' },
      { n: '05', t: 'zsh 补全',         d: '不仅补全命令，还会走你的云端目录树，路径也能按 Tab 补全。' },
      { n: '06', t: '纯 rust 单文件',   d: 'ratatui · crossterm · reqwest (rustls-tls)。无 OpenSSL 与 C 依赖。' },
      { n: '07', t: '分享链接',         d: '在购物车视图里直接创建、查看、保存、删除分享链接；可选密码保护。' },
      { n: '08', t: '对 agent 友好',    d: '非交互式登录、--json 输出、清晰的退出码。已包含 openclaw skill。' },
    ],
    sec2: '§ 02 · 特性',
    sec2Title: ['八件事', '都认真做了。'],
    sec2Lede: 'pikpaktui 是真正的客户端，不是 Web 界面的套壳。下面每一项都是针对 PikPak API 端到端实现的。',
    sec3: '§ 03 · 开始',
    sec3Headline: ['浏览.', '播放.', '脚本化.'],
    getStarted: '开始使用 ↳',
    cliRef: 'CLI 参考',
    license: 'apache-2.0 授权 · 无遥测 · 开源',
  },
  'zh-Hant': {
    tagline: 'pikpak 在你的終端機裡',
    eyebrow: 'pikpak · 在你的終端機裡。',
    overview: '§ 01 · 概覽',
    headline: ['瀏覽.', '播放.', '腳本化.'],
    lede: '一個用於 PikPak 雲端儲存的 TUI + CLI 客戶端。三欄米勒佈局、縮圖預覽、28 條子命令、影片串流至 iina/mpv/vlc、Shell 補全、離線下載 —— 全部以純 Rust 撰寫。',
    install: '↳ 安裝',
    docs: '閱讀文件',
    topLine: 'pikpaktui · pikpak 在你的終端機裡',
    topMid: 'tui + cli · 純 rust',
    footerTail: '三欄 · ratatui',
    interactiveChip: '互動',
    features: [
      { n: '01', t: '三欄 tui',         d: 'yazi 風格的米勒佈局，支援即時縮圖、語法高亮與鍵盤導覽。' },
      { n: '02', t: '28 條子命令',      d: 'ls · mv · cp · rm · download · upload · share · update。彩色輸出、--json、--dry-run。' },
      { n: '03', t: '影片串流至播放器', d: '按 Enter 選擇畫質，直接串流至 iina / mpv / vlc —— 檔案不落地。' },
      { n: '04', t: '離線下載',         d: '向 PikPak 伺服器提交磁力連結或 URL，從 TUI 裡查看任務狀態。' },
      { n: '05', t: 'zsh 補全',         d: '不只補全命令，還會走雲端目錄樹，路徑也能按 Tab 補全。' },
      { n: '06', t: '純 rust 單檔',     d: 'ratatui · crossterm · reqwest (rustls-tls)。無 OpenSSL 與 C 相依。' },
      { n: '07', t: '分享連結',         d: '在購物車視圖裡直接建立、檢視、保存、刪除分享連結；可選密碼保護。' },
      { n: '08', t: '對 agent 友善',    d: '非互動式登入、--json 輸出、清晰的結束碼。已內含 openclaw skill。' },
    ],
    sec2: '§ 02 · 特性',
    sec2Title: ['八件事', '都認真做了。'],
    sec2Lede: 'pikpaktui 是真正的客戶端，不是 Web 介面的套殼。下面每一項都是針對 PikPak API 端到端實作。',
    sec3: '§ 03 · 開始',
    sec3Headline: ['瀏覽.', '播放.', '腳本化.'],
    getStarted: '開始使用 ↳',
    cliRef: 'CLI 參考',
    license: 'apache-2.0 授權 · 無遙測 · 開源',
  },
} as const;

const t = copy[locale.code as 'zh' | 'zh-Hant'];
---
<DefaultLayout title={`${pikpaktui.title} — ${t.tagline}`} lang={locale.lang ?? locale.code}>
  <div class="page home">
    <TopBar
      brand={pikpaktui.title}
      version={pikpaktui.version}
      current="home"
      showStatus={false}
      githubHref={pikpaktui.githubUrl}
      nav={pikpaktui.nav()}
    >
      <Fragment slot="logo">
        <rect x="0"  y="0"  width="20" height="20" fill="var(--yellow)" />
        <rect x="20" y="0"  width="20" height="20" fill="var(--ink)" />
        <rect x="0"  y="20" width="20" height="20" fill="var(--ink)" />
        <rect x="20" y="20" width="20" height="20" fill="var(--red)" />
      </Fragment>
    </TopBar>

    <section class="hero">
      <div class="hero-top rule-b">
        <span class="t-mono-sm">{t.topLine}</span>
        <span class="t-mono-sm">{t.topMid}</span>
        <span class="t-mono-sm">{pikpaktui.version} · {pikpaktui.releaseDate}</span>
      </div>

      <div class="hero-grid grid12">
        <div class="hero-headline">
          <div class="hero-eyebrow">
            <span class="t-small">{t.overview}</span>
            <span class="t-mono-sm" style="color: var(--steel-5);">
              <Typewriter client:visible text={`// ${t.eyebrow}`} speed={24} delay={300} />
            </span>
          </div>
          <h1 class="t-display lower">
            <span class="hl-line"><BlockReveal client:visible delay={400} duration={520}>{t.headline[0]}</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:visible delay={760} duration={520} color="var(--red)">{t.headline[1]}</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:visible delay={1120} duration={520} color="var(--blue)">{t.headline[2]}</BlockReveal></span>
          </h1>

          <p class="hero-lede">{t.lede}</p>

          <div class="hero-cta">
            <a class="btn-block" href={pikpaktui.href(`/${locale.code}/install`)}>{t.install} {pikpaktui.version}</a>
            <a class="btn-block is-ghost" href={pikpaktui.href(`/${locale.code}/docs/getting-started`)}>{t.docs}</a>
            <span class="hero-cta-meta t-mono-sm">
              ⌘ <span>brew install Bengerthelorf/tap/pikpaktui</span>
            </span>
          </div>
        </div>

        <aside class="hero-device hero-device--image">
          <div class="device-head">
            <div class="t-small">tui.live</div>
            <div class="chip is-blue"><span class="dot"/>{t.interactiveChip}</div>
          </div>
          <img
            src={pikpaktui.href('/images/main.jpeg')}
            alt="pikpaktui tui"
            loading="eager"
            decoding="async"
          />
          <div class="device-footline">
            <span class="t-mono-sm">{t.footerTail}</span>
            <span class="t-mono-sm" style="color: var(--blue);">● live</span>
          </div>
        </aside>
      </div>
    </section>

    <section class="home-section home-principles">
      <div class="section-head">
        <div class="section-head-left">
          <div class="t-small">{t.sec2}</div>
          <h2 class="t-h1 lower">{t.sec2Title[0]}<br/>{t.sec2Title[1]}</h2>
        </div>
        <div class="section-head-right">
          <p class="t-body">{t.sec2Lede}</p>
        </div>
      </div>

      <div class="principles-grid">
        {t.features.map((it) => (
          <div class="principle">
            <div class="principle-n t-mono">{it.n}</div>
            <div class="principle-title t-h3 lower">{it.t}</div>
            <div class="principle-d">{it.d}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="home-cta">
      <div class="cta-inner">
        <div class="t-small" style="color: var(--steel-3);">{t.sec3}</div>
        <h2 class="t-display lower" style="color: var(--paper-pure);">
          <BlockReveal client:visible delay={200} color="var(--yellow)">{t.sec3Headline[0]}</BlockReveal><br/>
          <BlockReveal client:visible delay={700} color="var(--red)">{t.sec3Headline[1]}</BlockReveal><br/>
          <BlockReveal client:visible delay={1200} color="var(--blue)">{t.sec3Headline[2]}</BlockReveal>
        </h2>
        <div class="cta-buttons">
          <a class="btn-block" style="background: var(--paper-pure); color: var(--ink); border-color: var(--paper-pure);" href={pikpaktui.href(`/${locale.code}/docs/getting-started`)}>
            {t.getStarted}
          </a>
          <a class="btn-block" style="background: transparent; color: var(--paper-pure); border-color: var(--paper-pure);" href={pikpaktui.href(`/${locale.code}/docs/cli/commands`)}>
            {t.cliRef}
          </a>
        </div>
        <div class="cta-small t-mono-sm">{t.license}</div>
      </div>
    </section>

    <Footer product={pikpaktui} locale={locale.code} languages={pikpaktui.pageLanguages(locale.code, '/', ['en', 'zh', 'zh-Hant'])} />
  </div>
</DefaultLayout>

<style>
  .hero-device--image { padding: 0; background: var(--paper); }
  .hero-device--image img {
    display: block;
    width: 100%;
    height: auto;
    border-top: 1px solid var(--steel-3);
    border-bottom: 1px solid var(--steel-3);
  }
</style>
