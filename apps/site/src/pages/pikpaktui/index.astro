---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import { BlockReveal, Scramble, Typewriter } from '@snaix/docs-theme';
import { product } from '../../lib/product.ts';

const pikpaktui = product('pikpaktui');
const languages = pikpaktui.pageLanguages('en', '/');

const highlights = [
  { n: '01', t: 'three-column tui',   d: 'yazi-style miller layout with live thumbnails, syntax highlighting, and keyboard-driven navigation.' },
  { n: '02', t: '28 subcommands',     d: 'ls · mv · cp · rm · download · upload · share · update. colored output, --json mode, --dry-run.' },
  { n: '03', t: 'stream to iina/mpv', d: 'press enter on a video, pick quality, play straight from pikpak — never touches disk.' },
  { n: '04', t: 'offline downloads',  d: 'queue magnet links and URLs to pikpak servers. monitor tasks from the tui.' },
  { n: '05', t: 'zsh completions',    d: 'tab-complete cloud paths, not just commands — walks your pikpak tree in-line.' },
  { n: '06', t: 'pure rust, no c',    d: 'ratatui · crossterm · reqwest (rustls-tls). no openssl, no c deps, single binary.' },
  { n: '07', t: 'share links',        d: 'create, list, save, delete — plain or password-protected, right from the cart view.' },
  { n: '08', t: 'agent-friendly',     d: 'non-interactive login, --json output, clear exit codes. openclaw skill included.' },
];
---
<DefaultLayout title={`${pikpaktui.title} — ${pikpaktui.tagline}`}>
  <div class="page home">
    <TopBar
      brand={pikpaktui.title}
      version={pikpaktui.version}
      current="home"
      logoVariant="product"
      showStatus={false}
      githubHref={pikpaktui.githubUrl}
      nav={pikpaktui.nav()}
    />

    <section class="hero">
      <div class="hero-top rule-b">
        <span class="t-mono-sm">pikpaktui · {pikpaktui.tagline}</span>
        <span class="t-mono-sm">tui + cli · pure rust</span>
        <span class="t-mono-sm">{pikpaktui.version} · {pikpaktui.releaseDate}</span>
      </div>

      <div class="hero-grid grid12">
        <div class="hero-headline">
          <div class="hero-eyebrow">
            <span class="t-small">§ 01 · overview</span>
            <span class="t-mono-sm" style="color: var(--steel-5);">
              <Typewriter client:load text="// pikpak · in your terminal." speed={24} delay={300} />
            </span>
          </div>
          <h1 class="t-display lower">
            <span class="hl-line"><BlockReveal client:load delay={400} duration={520}>browse.</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:load delay={760} duration={520} color="var(--red)">stream.</BlockReveal></span>
            <span class="hl-line"><BlockReveal client:load delay={1120} duration={520} color="var(--blue)">script.</BlockReveal></span>
          </h1>

          <p class="hero-lede">
            a tui and cli client for pikpak cloud storage. three-column miller
            layout with thumbnails, 28 subcommands for shell and automation,
            video streaming to iina/mpv/vlc, shell completions, offline downloads —
            all in pure rust.
          </p>

          <div class="hero-cta">
            <a class="btn-block" href={pikpaktui.href('/install')}>↳ install {pikpaktui.version}</a>
            <a class="btn-block is-ghost" href={pikpaktui.href('/docs/getting-started')}>read the docs</a>
            <span class="hero-cta-meta t-mono-sm">
              ⌘ <span>brew install Bengerthelorf/tap/pikpaktui</span>
            </span>
          </div>
        </div>

        <aside class="hero-device hero-device--image">
          <div class="device-head">
            <div class="t-small">tui.live</div>
            <div class="chip is-blue"><span class="dot"/>interactive</div>
          </div>
          <img
            src={pikpaktui.href('/images/main.jpeg')}
            alt="pikpaktui three-column tui with thumbnails"
            loading="eager"
            decoding="async"
          />
          <div class="device-footline">
            <span class="t-mono-sm">miller layout · ratatui</span>
            <span class="t-mono-sm" style="color: var(--blue);">● live</span>
          </div>
        </aside>
      </div>

      <div class="hero-ribbon rule-t">
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">01</span>
            <span class="ribbon-label"><Scramble client:load text="browse with j/k" delay={200} /></span>
          </div>
          <div class="ribbon-sub">three panes: parent, current, preview. thumbnails for images and video.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">02</span>
            <span class="ribbon-label"><Scramble client:load text="stream any video" delay={350} /></span>
          </div>
          <div class="ribbon-sub">press enter on a video file. pick quality. iina / mpv / vlc — configurable player.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">03</span>
            <span class="ribbon-label"><Scramble client:load text="28 subcommands" delay={500} /></span>
          </div>
          <div class="ribbon-sub">ls, mv, cp, rm, download, upload, share, update. --json for pipelines, --dry-run for safety.</div>
        </div>
        <div class="ribbon-item">
          <div class="ribbon-head">
            <span class="t-small">04</span>
            <span class="ribbon-label"><Scramble client:load text="pure rust binary" delay={650} /></span>
          </div>
          <div class="ribbon-sub">rustls-tls. no openssl, no c dependencies. single static binary, updates itself in-place.</div>
        </div>
      </div>
    </section>

    <section class="home-section home-principles">
      <div class="section-head">
        <div class="section-head-left">
          <div class="t-small">§ 02 · features</div>
          <h2 class="t-h1 lower">eight things<br/>it actually does.</h2>
        </div>
        <div class="section-head-right">
          <p class="t-body">
            pikpaktui is a real client, not a wrapper around the web ui. every
            action below is implemented end-to-end against the pikpak api.
          </p>
        </div>
      </div>

      <div class="principles-grid">
        {highlights.map((it) => (
          <div class="principle">
            <div class="principle-n t-mono">{it.n}</div>
            <div class="principle-title t-h3 lower">{it.t}</div>
            <div class="principle-d">{it.d}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="home-cta">
      <div class="cta-inner">
        <div class="t-small" style="color: var(--steel-3);">§ 03 · begin</div>
        <h2 class="t-display lower" style="color: var(--paper-pure);">
          <BlockReveal client:load delay={200} color="var(--yellow)">browse.</BlockReveal><br/>
          <BlockReveal client:load delay={700} color="var(--red)">stream.</BlockReveal><br/>
          <BlockReveal client:load delay={1200} color="var(--blue)">script.</BlockReveal>
        </h2>
        <div class="cta-buttons">
          <a class="btn-block" style="background: var(--paper-pure); color: var(--ink); border-color: var(--paper-pure);" href={pikpaktui.href('/docs/getting-started')}>
            get started ↳
          </a>
          <a class="btn-block" style="background: transparent; color: var(--paper-pure); border-color: var(--paper-pure);" href={pikpaktui.href('/docs/cli/commands')}>
            cli reference
          </a>
        </div>
        <div class="cta-small t-mono-sm">
          apache-2.0 licensed · no telemetry · open source
        </div>
      </div>
    </section>

    <Footer product={pikpaktui} locale="en" languages={languages} />
  </div>
</DefaultLayout>

<style>
  .hero-device--image {
    padding: 0;
    background: var(--paper);
  }
  .hero-device--image img {
    display: block;
    width: 100%;
    height: auto;
    border-top: 1px solid var(--steel-3);
    border-bottom: 1px solid var(--steel-3);
  }
</style>
