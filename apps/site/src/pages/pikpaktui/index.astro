---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import PkTuiFrame from '@snaix/docs-theme/components/PkTuiFrame.astro';
import { BlockReveal, Scramble, Tally, Typewriter } from '@snaix/docs-theme';
import '@snaix/docs-theme/styles/pikpak.css';
import { product } from '../../lib/product.ts';

const pikpaktui = product('pikpaktui');

const nav = [
  { id: 'home',      label: 'overview',  href: pikpaktui.href('/') },
  { id: 'keys',      label: 'keymap',    href: '#keys' },
  { id: 'flow',      label: 'flow',      href: '#flow' },
  { id: 'docs',      label: 'docs',      href: pikpaktui.href('/docs/getting-started') },
  { id: 'commands',  label: 'cli',       href: pikpaktui.href('/commands') },
  { id: 'install',   label: 'install',   href: pikpaktui.href('/install') },
  { id: 'changelog', label: 'changelog', href: pikpaktui.href('/changelog') },
];

const keys = [
  { n: '01', k: ['j','k'], v: 'move',      d: 'down / up by one row. vim habits transfer.' },
  { n: '02', k: ['h','l'], v: 'back · in', d: 'pop to parent pane, push into folder.' },
  { n: '03', k: ['Enter'], v: 'open',      d: 'descend into a dir or select a file for ops.' },
  { n: '04', k: ['d'],     v: 'download',  d: 'queue current file or selection. resumable.' },
  { n: '05', k: ['space'], v: 'mark',      d: 'multi-select. works across pages.' },
  { n: '06', k: ['/'],     v: 'filter',    d: 'incremental regex filter on the current pane.' },
  { n: '07', k: ['r'],     v: 'refresh',   d: 'refetch the current directory.' },
  { n: '08', k: ['q'],     v: 'quit',      d: 'exit cleanly. queue persists to disk.' },
];
---
<DefaultLayout title={`${pikpaktui.title} — ${pikpaktui.tagline}`}>
  <div class="page">
    <TopBar
      brand={pikpaktui.title}
      version={pikpaktui.version}
      current="home"
      githubHref={pikpaktui.githubUrl}
      nav={nav}
    >
      <Fragment slot="logo">
        <rect x="0"  y="0"  width="20" height="20" fill="var(--yellow)" />
        <rect x="20" y="0"  width="20" height="20" fill="var(--ink)" />
        <rect x="0"  y="20" width="20" height="20" fill="var(--ink)" />
        <rect x="20" y="20" width="20" height="20" fill="var(--red)" />
      </Fragment>
    </TopBar>

    <section class="pk-hero">
      <div class="pk-hero-top rule-b">
        <span class="t-mono-sm">pikpaktui / pikpak in your terminal</span>
        <span class="t-mono-sm">tui · cli · ratatui</span>
        <span class="t-mono-sm">{pikpaktui.version} · {pikpaktui.releaseDate}</span>
      </div>

      <div class="pk-hero-grid">
        <div class="pk-hero-left">
          <div class="pk-hero-eyebrow">
            <span class="t-small">§ 01 · overview</span>
            <span class="t-mono-sm" style="color: var(--steel-5);">
              <Typewriter client:visible text="// tui · keyboard-first" speed={24} delay={300} />
            </span>
          </div>
          <h1 class="pk-hero-title lower">
            <span class="hl-line"><BlockReveal client:visible delay={300} duration={520} color="var(--yellow)">pikpak.</BlockReveal></span>
            <span class="hl-line r2"><BlockReveal client:visible delay={700} duration={520}>in the<em>tui</em></BlockReveal></span>
          </h1>
          <p class="pk-lede">
            the browser is a lie. pikpaktui brings your cloud drive into the
            terminal — three panes, ratatui, miller-column navigation, inline
            preview. j/k to move, <code>enter</code> to open, <code>d</code>
            to download. no mouse. no modal. no tabs.
          </p>
          <div class="pk-cta">
            <a class="btn-block" href="#install">↳ install {pikpaktui.version}</a>
            <a class="btn-block is-ghost" href="#keys">read keymap</a>
            <span class="pk-cta-meta">
              ⌘ <span>cargo install pikpaktui</span>
            </span>
          </div>
        </div>

        <aside class="pk-hero-right">
          <PkTuiFrame />
        </aside>
      </div>

      <div class="pk-ribbon">
        <div class="item">
          <span class="t-small">01</span>
          <div class="lbl"><Scramble client:visible text="three panes" delay={200} /></div>
          <div class="sub">miller columns: roots, current directory, live preview of the focused item.</div>
        </div>
        <div class="item">
          <span class="t-small">02</span>
          <div class="lbl"><Scramble client:visible text="keyboard only" delay={320} /></div>
          <div class="sub">vim-style motion. j/k, h/l, enter, q. 26 keys do everything.</div>
        </div>
        <div class="item">
          <span class="t-small">03</span>
          <div class="lbl"><Scramble client:visible text="kitty graphics" delay={440} /></div>
          <div class="sub">inline jpeg/png/mkv thumbs in terminals that speak the kitty graphics protocol.</div>
        </div>
        <div class="item">
          <span class="t-small">04</span>
          <div class="lbl"><Scramble client:visible text="resumable dl" delay={560} /></div>
          <div class="sub">download queue lives on disk. kill the process, restart, pick up.</div>
        </div>
      </div>
    </section>

    <section class="pk-section" id="keys">
      <div class="pk-section-head">
        <div class="lhs">
          <div class="t-small">§ 02 · keymap</div>
          <h2 class="t-h1 lower">26 keys,<br />everything.</h2>
        </div>
        <div class="rhs">
          <p class="t-body">
            the whole tui is a finite state machine on top of a keymap. there
            are no hidden gestures, no mouse-only corners, no right-click
            menus. read this card, you can drive pikpaktui.
          </p>
        </div>
      </div>
      <div class="pk-keymap">
        {keys.map((k) => (
          <div class="pk-keymap-cell">
            <div class="idx">{k.n}</div>
            <div class="keys">{k.k.map((kk) => <kbd>{kk}</kbd>)}</div>
            <div class="verb lower">{k.v}</div>
            <div class="desc">{k.d}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="pk-section" id="flow">
      <div class="pk-section-head">
        <div class="lhs">
          <div class="t-small">§ 03 · flow</div>
          <h2 class="t-h1 lower">open.<br />pick.<br />pull.</h2>
        </div>
        <div class="rhs">
          <p class="t-body">
            the whole round-trip takes three keys for small files and four
            for big ones. the fourth is <code>q</code> when you are done.
          </p>
        </div>
      </div>
      <div class="pk-flow">
        <div class="step">
          <div class="n">01 · open</div>
          <div class="h lower">launch the tui.</div>
          <div class="p"><code>pikpaktui</code> in any terminal. three panes appear. roots on the left.</div>
          <div class="art" />
        </div>
        <div class="step">
          <div class="n">02 · pick</div>
          <div class="h lower">navigate, mark.</div>
          <div class="p">j/k down a directory, l to descend, space to multi-select across pages.</div>
          <div class="art" />
        </div>
        <div class="step">
          <div class="n">03 · pull</div>
          <div class="h lower">queue the download.</div>
          <div class="p"><code>d</code> queues. the queue lives on disk. kill the process, restart, resume.</div>
          <div class="art" />
        </div>
      </div>
    </section>

    <section class="pk-section">
      <div class="pk-metrics">
        <div class="pk-metric">
          <div class="n"><Tally client:visible to={26} duration={900} /></div>
          <div class="c">keys · complete</div>
        </div>
        <div class="pk-metric">
          <div class="n"><Tally client:visible to={3} duration={700} /></div>
          <div class="c">panes · miller</div>
        </div>
        <div class="pk-metric">
          <div class="n">ratatui</div>
          <div class="c">render · crossterm</div>
        </div>
        <div class="pk-metric">
          <div class="n"><Tally client:visible to={0} duration={600} /></div>
          <div class="c">telemetry · forever</div>
        </div>
      </div>
    </section>

    <section class="pk-cta-full" id="install">
      <div class="pk-cta-inner">
        <div class="t-small" style="color: rgba(10,10,11,0.6);">§ 04 · install</div>
        <h2 class="lower">
          <BlockReveal client:visible delay={200} color="var(--ink)">one binary.</BlockReveal><br />
          <BlockReveal client:visible delay={700} color="var(--red)">zero config.</BlockReveal>
        </h2>
        <div class="buttons">
          <a class="btn-block" style="background: var(--c-ink-0); color: var(--c-yellow); border-color: var(--c-ink-0);" href={pikpaktui.href('/install')}>
            cargo install pikpaktui ↳
          </a>
          <a class="btn-block" style="background: transparent; color: var(--c-ink-0); border-color: var(--c-ink-0);" href={`${pikpaktui.githubUrl}/releases`}>
            prebuilt · releases
          </a>
        </div>
        <div class="t-mono-sm" style="margin-top: 28px; color: rgba(10,10,11,0.6);">
          mit · apache-2.0 · nothing phones home
        </div>
      </div>
    </section>

    <Footer product={pikpaktui} locale="en" languages={pikpaktui.pageLanguages('en', '/', ['en', 'zh', 'zh-Hant'])} />
  </div>
</DefaultLayout>
