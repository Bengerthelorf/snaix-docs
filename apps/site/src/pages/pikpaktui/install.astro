---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import { BlockReveal, InstallTabs } from '@snaix/docs-theme';
import type { InstallStep } from '@snaix/docs-theme';
import { product } from '../../lib/product.ts';

const pikpaktui = product('pikpaktui');
const versionBare = pikpaktui.version.replace(/^v/, '');

const steps: InstallStep[] = [
  {
    title: 'verify',
    description: 'confirm the binary is on your $PATH.',
    panelLabel: 'verification',
    script: [
      { type: 'prompt', text: 'pikpaktui --version' },
      { type: 'out',    text: `pikpaktui ${versionBare}`, pause: 160 },
    ],
  },
  {
    title: 'log in',
    description: 'authenticate once. credentials live at ~/.config/pikpaktui/login.yaml — never sent anywhere except PikPak.',
    panelLabel: 'login',
    script: [
      { type: 'prompt', text: 'pikpaktui login' },
      { type: 'out',    text: 'email: you@example.com',                       pause: 220 },
      { type: 'out',    text: 'password: ********',                            pause: 220 },
      { type: 'ok',     text: 'session saved to ~/.config/pikpaktui/login.yaml', pause: 180 },
    ],
  },
  {
    title: 'first browse',
    description: 'list your drive root, or launch the tui. you\'re online.',
    panelLabel: 'first-browse',
    script: [
      { type: 'prompt', text: 'pikpaktui ls /', pause: 160 },
      { type: 'out',    text: 'Downloads/', pause: 80 },
      { type: 'out',    text: 'Movies/',    pause: 80 },
      { type: 'out',    text: 'My Pack/',   pause: 80 },
      { type: 'blank' },
      { type: 'prompt', text: 'pikpaktui',   pause: 220 },
      { type: 'out',    text: 'entering tui · press ? for help', pause: 160 },
    ],
    footer: { href: '/pikpaktui/docs/getting-started', label: 'read the full walkthrough →' },
  },
];
---
<DefaultLayout title={`${pikpaktui.title} · install`}>
  <div class="page install">
    <TopBar
      brand={pikpaktui.title}
      version={pikpaktui.version}
      current="install"
      githubHref={pikpaktui.githubUrl}
      nav={pikpaktui.nav()}
    />

    <section class="install-hero">
      <div class="t-small" style="color: var(--yellow);">§ install</div>
      <h1 class="install-title lower">
        <BlockReveal client:load>four</BlockReveal> <BlockReveal client:load color="var(--red)" delay={300}>ways</BlockReveal><br/>
        <BlockReveal client:load color="var(--blue)" delay={600}>in.</BlockReveal>
      </h1>
      <p class="t-body" style="margin-top: 24px; max-width: 560px;">
        pikpaktui is a single static binary. pick a channel, paste one
        line, you're browsing your pikpak drive in under a minute.
      </p>
    </section>

    <InstallTabs client:load options={pikpaktui.install} steps={steps} />

    <Footer product={pikpaktui} locale="en" />
  </div>
</DefaultLayout>
