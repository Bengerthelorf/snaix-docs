---
import DefaultLayout from '@snaix/docs-theme/layouts/DefaultLayout.astro';
import TopBar from '@snaix/docs-theme/components/TopBar.astro';
import Footer from '@snaix/docs-theme/components/Footer.astro';
import { BlockReveal, InstallTabs } from '@snaix/docs-theme';
import type { CmdLine } from '@snaix/docs-theme';
import { product } from '../../lib/product.ts';

const pikpaktui = product('pikpaktui');
const versionBare = pikpaktui.version.replace(/^v/, '');

const verifyScript: CmdLine[] = [
  { type: 'prompt', text: 'pikpaktui --version' },
  { type: 'out',    text: `pikpaktui ${versionBare}`, pause: 160 },
  { type: 'blank' },
  { type: 'prompt', text: 'pikpaktui ls /', pause: 220 },
  { type: 'out',    text: 'drwxr-xr-x   Downloads/', pause: 120 },
  { type: 'out',    text: 'drwxr-xr-x   Movies/',    pause: 80 },
  { type: 'ok',     text: 'connected',               pause: 160 },
];

const firstRunScript: CmdLine[] = [
  { type: 'prompt', text: 'pikpaktui' },
  { type: 'out',    text: 'login · pikpak email + password', pause: 180 },
  { type: 'ok',     text: 'session saved to ~/.config/pikpaktui/',  pause: 180 },
  { type: 'out',    text: 'entering tui · press h for help',         pause: 160 },
];
---
<DefaultLayout title={`${pikpaktui.title} · install`}>
  <div class="page install">
    <TopBar
      brand={pikpaktui.title}
      version={pikpaktui.version}
      current="install"
      githubHref={pikpaktui.githubUrl}
      nav={pikpaktui.nav()}
    />

    <section class="install-hero">
      <div class="t-small" style="color: var(--red);">§ install</div>
      <h1 class="install-title lower">
        <BlockReveal client:load>four</BlockReveal> <BlockReveal client:load color="var(--red)" delay={300}>ways</BlockReveal><br/>
        <BlockReveal client:load color="var(--blue)" delay={600}>in.</BlockReveal>
      </h1>
      <p class="t-body" style="margin-top: 24px; max-width: 560px;">
        pikpaktui is a single static binary. pick a channel, paste one
        line, you're browsing your pikpak drive in under a minute.
      </p>
    </section>

    <InstallTabs client:load options={pikpaktui.install} verifyScript={verifyScript} firstCopyScript={firstRunScript} />

    <Footer product={pikpaktui} locale="en" />
  </div>
</DefaultLayout>
